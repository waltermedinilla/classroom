<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Monitor - Superadmin</title>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,0..200" />
  <link rel="icon" type="image/png" href="/favicon.png">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .monitor-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 16px;
      margin-bottom: 24px;
    }
    .metric-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 20px;
      box-shadow: var(--shadow-sm);
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .metric-icon {
      font-size: 28px;
      margin-bottom: 4px;
      color: var(--text-secondary);
    }
    .metric-value {
      font-size: 32px;
      font-weight: 800;
      line-height: 1;
      color: var(--text-primary, #1a1a2e);
    }
    .metric-label {
      font-size: 12px;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: .5px;
      font-weight: 600;
    }
    .metric-sub {
      font-size: 12px;
      color: var(--text-secondary);
      margin-top: 2px;
    }
    .bar-track {
      height: 8px;
      background: var(--border);
      border-radius: 4px;
      overflow: hidden;
      margin-top: 8px;
    }
    .bar-fill {
      height: 100%;
      border-radius: 4px;
      transition: width .6s ease;
    }
    .status-dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      display: inline-block;
      margin-right: 4px;
    }
    .refresh-bar {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 20px;
      flex-wrap: wrap;
    }
    .section-title {
      font-size: 12px;
      font-weight: 700;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: .6px;
      margin: 24px 0 10px;
    }
    @media (max-width: 600px) {
      .monitor-grid { grid-template-columns: 1fr 1fr; }
      .metric-value { font-size: 26px; }
    }
  </style>
</head>
<body>
  <%- include('../partials/header') %>
  <main class="main-content">
    <%- include('../partials/superadmin-nav') %>

    <div class="section-header" style="margin-bottom:16px">
      <span class="material-symbols-outlined section-icon" style="color:#1a73e8">monitor_heart</span>
      <h2 style="margin:0">Monitor del Sistema</h2>
    </div>

    <div class="refresh-bar">
      <span class="status-dot" id="statusDot" style="background:#34a853"></span>
      <span style="font-size:13px;color:var(--text-secondary)">Actualizado: <strong id="lastUpdated">—</strong></span>
      <button class="btn btn-outline" style="font-size:12px;padding:4px 14px" onclick="fetchStats()">
        <span class="material-symbols-outlined" style="font-size:15px;vertical-align:middle">refresh</span>
        Actualizar
      </button>
      <span style="font-size:12px;color:var(--text-secondary);margin-left:auto" id="countdown"></span>
    </div>

    <!-- Usuarios -->
    <div class="section-title">Usuarios</div>
    <div class="monitor-grid">
      <div class="metric-card" style="border-top:3px solid #1a73e8">
        <span class="material-symbols-outlined metric-icon" style="color:#1a73e8">group</span>
        <div class="metric-label">Activos ahora</div>
        <div class="metric-value" id="m-active">—</div>
        <div class="metric-sub">últimos 15 minutos</div>
      </div>
      <div class="metric-card">
        <span class="material-symbols-outlined metric-icon">people</span>
        <div class="metric-label">Total usuarios</div>
        <div class="metric-value" id="m-total">—</div>
        <div class="metric-sub" id="m-active-pct">—</div>
      </div>
      <div class="metric-card">
        <span class="material-symbols-outlined metric-icon">domain</span>
        <div class="metric-label">Escuelas</div>
        <div class="metric-value" id="m-schools">—</div>
        <div class="metric-sub">en la plataforma</div>
      </div>
    </div>

    <!-- Memoria -->
    <div class="section-title">Memoria del servidor</div>
    <div class="monitor-grid">
      <div class="metric-card" style="grid-column: span 2">
        <div style="display:flex;justify-content:space-between;align-items:center">
          <div>
            <span class="material-symbols-outlined metric-icon" style="font-size:22px">memory</span>
            <span class="metric-label">RAM del sistema</span>
          </div>
          <div style="text-align:right">
            <span class="metric-value" style="font-size:24px" id="m-ram-used">—</span>
            <span style="font-size:14px;color:var(--text-secondary)" id="m-ram-total"> / — MB</span>
          </div>
        </div>
        <div class="bar-track">
          <div class="bar-fill" id="m-ram-bar" style="width:0%;background:#1a73e8"></div>
        </div>
        <div class="metric-sub" id="m-ram-pct">—</div>
      </div>
      <div class="metric-card">
        <span class="material-symbols-outlined metric-icon" style="color:#9334e6">javascript</span>
        <div class="metric-label">Heap Node.js</div>
        <div class="metric-value" style="font-size:24px" id="m-heap-used">—</div>
        <div class="metric-sub" id="m-heap-total">— MB total · — MB RSS</div>
      </div>
      <div class="metric-card">
        <span class="material-symbols-outlined metric-icon" style="color:#ea4335">storage</span>
        <div class="metric-label">RAM libre</div>
        <div class="metric-value" style="font-size:24px" id="m-ram-free">—</div>
        <div class="metric-sub">MB disponibles</div>
      </div>
    </div>

    <!-- CPU / Carga -->
    <div class="section-title">Carga del sistema</div>
    <div class="monitor-grid">
      <div class="metric-card" style="grid-column: span 2">
        <div style="display:flex;justify-content:space-between;align-items:center">
          <div>
            <span class="material-symbols-outlined metric-icon" style="font-size:22px;color:#ea8600">speed</span>
            <span class="metric-label">Load average (1 min)</span>
          </div>
          <div style="text-align:right">
            <span class="metric-value" style="font-size:24px" id="m-load1">—</span>
            <span style="font-size:13px;color:var(--text-secondary)" id="m-load-cpus"> / — CPUs</span>
          </div>
        </div>
        <div class="bar-track">
          <div class="bar-fill" id="m-load-bar" style="width:0%;background:#ea8600"></div>
        </div>
        <div class="metric-sub" id="m-load-pct">—</div>
      </div>
      <div class="metric-card">
        <span class="material-symbols-outlined metric-icon">query_stats</span>
        <div class="metric-label">Load avg 5 min</div>
        <div class="metric-value" style="font-size:24px" id="m-load5">—</div>
      </div>
      <div class="metric-card">
        <span class="material-symbols-outlined metric-icon">history</span>
        <div class="metric-label">Load avg 15 min</div>
        <div class="metric-value" style="font-size:24px" id="m-load15">—</div>
      </div>
    </div>

    <!-- Uptime -->
    <div class="section-title">Tiempo activo</div>
    <div class="monitor-grid">
      <div class="metric-card" style="border-top:3px solid #34a853">
        <span class="material-symbols-outlined metric-icon" style="color:#34a853">electric_bolt</span>
        <div class="metric-label">Proceso Node.js</div>
        <div class="metric-value" style="font-size:22px" id="m-uptime-proc">—</div>
        <div class="metric-sub">desde el último reinicio</div>
      </div>
      <div class="metric-card">
        <span class="material-symbols-outlined metric-icon">dns</span>
        <div class="metric-label">Sistema operativo</div>
        <div class="metric-value" style="font-size:22px" id="m-uptime-sys">—</div>
        <div class="metric-sub">uptime del servidor</div>
      </div>
    </div>

  </main>
  <%- include('../partials/footer') %>

  <script>
    let countdown = 30;
    let timer;

    function formatBytes(mb) {
      if (mb >= 1024) return (mb / 1024).toFixed(1) + ' GB';
      return mb + ' MB';
    }

    function formatUptime(seconds) {
      const d = Math.floor(seconds / 86400);
      const h = Math.floor((seconds % 86400) / 3600);
      const m = Math.floor((seconds % 3600) / 60);
      if (d > 0) return `${d}d ${h}h ${m}m`;
      if (h > 0) return `${h}h ${m}m`;
      return `${m}m`;
    }

    function barColor(pct) {
      if (pct < 60) return '#34a853';
      if (pct < 85) return '#ea8600';
      return '#ea4335';
    }

    function setText(id, val) {
      const el = document.getElementById(id);
      if (el) el.textContent = val;
    }

    async function fetchStats() {
      document.getElementById('statusDot').style.background = '#ea8600';
      try {
        const res  = await fetch('/superadmin/monitor/stats');
        const data = await res.json();

        // Usuarios
        setText('m-active', data.users.active);
        setText('m-total',  data.users.total);
        const pct = data.users.total > 0
          ? Math.round((data.users.active / data.users.total) * 100)
          : 0;
        setText('m-active-pct', `${pct}% del total en sesión`);
        setText('m-schools', data.schools);

        // RAM
        setText('m-ram-used',  formatBytes(data.memory.used));
        setText('m-ram-total', ' / ' + formatBytes(data.memory.total));
        setText('m-ram-free',  formatBytes(data.memory.free));
        setText('m-ram-pct',   `${data.memory.percent}% utilizada · ${data.memory.free} MB libres`);
        const ramBar = document.getElementById('m-ram-bar');
        ramBar.style.width   = data.memory.percent + '%';
        ramBar.style.background = barColor(data.memory.percent);

        // Heap
        setText('m-heap-used',  formatBytes(data.heap.used));
        setText('m-heap-total', `${data.heap.total} MB total · ${data.heap.rss} MB RSS`);

        // Load
        setText('m-load1',    data.load.avg1);
        setText('m-load5',    data.load.avg5);
        setText('m-load15',   data.load.avg15);
        setText('m-load-cpus', ` / ${data.load.cpus} CPUs`);
        setText('m-load-pct',  `${data.load.percent}% de uso estimado`);
        const loadBar = document.getElementById('m-load-bar');
        loadBar.style.width      = Math.min(100, data.load.percent) + '%';
        loadBar.style.background = barColor(data.load.percent);

        // Uptime
        setText('m-uptime-proc', formatUptime(data.uptime.process));
        setText('m-uptime-sys',  formatUptime(data.uptime.system));

        // Timestamp
        const ts = new Date(data.timestamp);
        setText('lastUpdated', ts.toLocaleTimeString('es-AR'));

        document.getElementById('statusDot').style.background = '#34a853';
      } catch {
        document.getElementById('statusDot').style.background = '#ea4335';
      }

      // Reinicia el contador
      countdown = 30;
    }

    function tick() {
      countdown--;
      setText('countdown', `Próxima actualización en ${countdown}s`);
      if (countdown <= 0) fetchStats();
    }

    fetchStats();
    timer = setInterval(tick, 1000);
  </script>
</body>
</html>
