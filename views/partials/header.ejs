<script>
  (function () {
    var t = localStorage.getItem('theme') || 'light';
    document.documentElement.setAttribute('data-theme', t);
  })();
</script>
<%
// ── Detectar tema activo por fecha ──────────────────────────────────────────
const _activeTheme = (function() {
  if (!school?.themes?.length) return null;
  const now  = new Date();
  const mmdd = String(now.getMonth()+1).padStart(2,'0') + '-' + String(now.getDate()).padStart(2,'0');
  function inRange(s, e) {
    if (!s || !e) return false;
    return s > e ? (mmdd >= s || mmdd <= e) : (mmdd >= s && mmdd <= e);
  }
  return school.themes.find(t => t.status === 'accepted' && inRange(t.startDate, t.endDate)) || null;
})();
%>
<% if (_activeTheme) { %>
<%
  const _slug = _activeTheme.slug;
  const _cfg  = _activeTheme.config || {};
  const _speedMap = { slow:[7,13], normal:[3,7], fast:[1,3] };
  // Paleta de confetti según tema
  const _confettiPalettes = {
    'mundial-argentina': ['#75aadb','#ffffff','#5b9dc9'],
    'halloween':         ['#ff6600','#cc3300','#ff8800','#440066'],
    'navidad':           ['#ffffff','#d4edda','#f8d7da','#c8f0c8'],
    'dia-bandera':       ['#75aadb','#ffffff','#5b9dc9'],
    'independencia':     ['#75aadb','#ffffff','#ffd700'],
    'dia-maestro':       ['#4CAF50','#2196F3','#FF9800','#9C27B0'],
    'primavera':         ['#ff69b4','#90ee90','#ff1493','#98fb98','#fffacd'],
    'carnaval':          ['#ff0000','#00cc00','#0000ff','#ffff00','#ff00ff','#00ffff'],
  };
  const _colors = _confettiPalettes[_slug] || ['#74acdf','#ffffff'];
  const _confettiCfg = _cfg.confetti || {};
  const _count = Math.min(80, Math.max(5, parseInt(_confettiCfg.confettiCount) || 30));
  const [_sMin, _sMax] = _speedMap[_confettiCfg.confettiSpeed] || _speedMap.normal;
%>
<style>
  <%- /* ── Confetti ── */ %>
  <% if (_confettiCfg.enabled !== false) { %>
  @keyframes confettiFall {
    0%   { transform: translateY(-10px) rotate(0deg);   opacity: 1; }
    100% { transform: translateY(100vh) rotate(720deg); opacity: 0; }
  }
  .confetti-piece {
    position: fixed; top: -10px; border-radius: 2px;
    pointer-events: none; z-index: 9999;
    animation: confettiFall linear infinite;
  }
  <% } %>

  <%- /* ── Borde en botones (mundial / independencia) ── */ %>
  <% if (_cfg.buttonBorder?.enabled !== false && (_slug === 'mundial-argentina' || _slug === 'independencia')) { %>
  body.theme-active .btn-primary {
    box-shadow: 0 0 0 2px #74acdf, 0 0 0 4px #fff, 0 0 0 5px #74acdf, 0 2px 8px rgba(26,115,232,.3);
  }
  <% } %>

  <%- /* ── Colores nav ── */ %>
  <% if (_cfg.navColors?.enabled !== false) { %>
    <% if (_slug === 'mundial-argentina' || _slug === 'dia-bandera' || _slug === 'independencia') { %>
    body.theme-active .header-school-name {
      background: linear-gradient(90deg,#74acdf 0%,#fff 45%,#74acdf 100%);
      color:#1a3a6b!important; padding:4px 16px; border-radius:20px;
      font-weight:600; border:1.5px solid #74acdf;
    }
    <% } else if (_slug === 'halloween') { %>
    body.theme-active .header-school-name {
      background: linear-gradient(90deg,#ff6600,#220033);
      color:#fff!important; padding:4px 16px; border-radius:20px; font-weight:600;
    }
    body.theme-active .header { background: #1a0a2e!important; }
    <% } else if (_slug === 'navidad') { %>
    body.theme-active .header-school-name {
      background: linear-gradient(90deg,#c0392b,#27ae60);
      color:#fff!important; padding:4px 16px; border-radius:20px; font-weight:600;
    }
    <% } else if (_slug === 'primavera') { %>
    body.theme-active .header-school-name {
      background: linear-gradient(90deg,#ff69b4,#90ee90);
      color:#fff!important; padding:4px 16px; border-radius:20px; font-weight:600;
    }
    <% } else if (_slug === 'carnaval') { %>
    body.theme-active .header-school-name {
      background: linear-gradient(90deg,#ff0080,#7700ff,#0055ff);
      color:#fff!important; padding:4px 16px; border-radius:20px; font-weight:600;
    }
    <% } %>
  <% } %>

  <%- /* ── Banderitas flotantes ── */ %>
  <% if (_cfg.flags?.enabled !== false && (_slug === 'mundial-argentina' || _slug === 'dia-bandera' || _slug === 'independencia')) { %>
  body.theme-active .th-flag {
    position:fixed; font-size:30px; pointer-events:none; z-index:50; opacity:.8;
    animation:flagFloat 4s ease-in-out infinite;
  }
  body.theme-active .th-flag-1 { bottom:90px;  right:80px; animation-delay:0s; }
  body.theme-active .th-flag-2 { bottom:90px;  left:24px;  animation-delay:1.5s; }
  body.theme-active .th-flag-3 { bottom:180px; right:50px; animation-delay:.8s; }
  @keyframes flagFloat {
    0%,100%{ transform:translateY(0) rotate(-6deg); }
    50%    { transform:translateY(-12px) rotate(6deg); }
  }
  <% } %>

  <%- /* ── Arañas Halloween ── */ %>
  <% if (_cfg.spiders?.enabled !== false && _slug === 'halloween') { %>
  body.theme-active .th-spider {
    position:fixed; font-size:28px; pointer-events:none; z-index:50; opacity:.8;
    animation:spiderDrop 6s ease-in-out infinite;
  }
  body.theme-active .th-spider-1 { top:60px; right:60px;  animation-delay:0s; }
  body.theme-active .th-spider-2 { top:60px; left:40px;   animation-delay:2s; }
  body.theme-active .th-spider-3 { top:100px; right:200px; animation-delay:4s; }
  @keyframes spiderDrop {
    0%,100%{ transform:translateY(0); } 50%{ transform:translateY(30px); }
  }
  <% } %>

  <%- /* ── Luces navideñas ── */ %>
  <% if (_cfg.lights?.enabled !== false && _slug === 'navidad') { %>
  body.theme-active .header::after {
    content:'🎄🎅🤶⭐🎁🔔🕯️🎄';
    position:absolute; bottom:-20px; left:0; width:100%;
    font-size:18px; letter-spacing:12px; pointer-events:none;
    animation:lightsBlink 2s ease-in-out infinite;
  }
  @keyframes lightsBlink {
    0%,100%{ opacity:1; } 50%{ opacity:.4; }
  }
  body.theme-active .header { position:relative; overflow:visible; }
  <% } %>
</style>

<% if (_cfg.flags?.enabled !== false && (_slug === 'mundial-argentina' || _slug === 'dia-bandera' || _slug === 'independencia')) { %>
<div class="th-flag th-flag-1">🇦🇷</div>
<div class="th-flag th-flag-2">🇦🇷</div>
<div class="th-flag th-flag-3">🎽</div>
<% } %>
<% if (_cfg.spiders?.enabled !== false && _slug === 'halloween') { %>
<div class="th-spider th-spider-1">🕷️</div>
<div class="th-spider th-spider-2">🕸️</div>
<div class="th-spider th-spider-3">🕷️</div>
<% } %>

<script>
  (function () {
    var key = 'themeActive_<%= school._id %>';
    if (localStorage.getItem(key) !== 'false') document.body.classList.add('theme-active');
  })();

  <% if (_confettiCfg.enabled !== false) { %>
  (function () {
    if (localStorage.getItem('themeActive_<%= school._id %>') === 'false') return;
    var colors = <%- JSON.stringify(_colors) %>;
    var count = <%= _count %>, sMin = <%= _sMin %>, sMax = <%= _sMax %>;
    for (var i = 0; i < count; i++) {
      var el = document.createElement('div');
      el.className = 'confetti-piece';
      el.style.left              = Math.random() * 100 + 'vw';
      el.style.background        = colors[Math.floor(Math.random() * colors.length)];
      el.style.animationDuration = (Math.random() * (sMax - sMin) + sMin) + 's';
      el.style.animationDelay    = (Math.random() * 6) + 's';
      el.style.width             = (Math.random() * 6 + 5) + 'px';
      el.style.height            = (Math.random() * 6 + 5) + 'px';
      <% if (_slug === 'navidad') { %>el.style.borderRadius = '50%';<% } %>
      document.body.appendChild(el);
    }
  })();
  <% } %>

  function toggleTheme() {
    var key    = 'themeActive_<%= school._id %>';
    var active = document.body.classList.toggle('theme-active');
    localStorage.setItem(key, active ? 'true' : 'false');
    location.reload();
  }
</script>
<% } %>
<% if (impersonating) { %>
<style>
  .header { top: 44px; }
  .main-content { margin-top: 124px; }
</style>
<div class="impersonation-bar">
  <span class="material-symbols-outlined">visibility</span>
  Estás viendo como <strong><%= user ? user.name : '' %></strong>
  <span class="role-badge role-<%= user ? user.role : '' %>" style="font-size:11px;padding:2px 10px"><%= user ? (roleNames[user.role] || user.role) : '' %></span>
  <a href="/exit-impersonate" class="impersonation-exit">
    <span class="material-symbols-outlined">logout</span>
    Volver a mi cuenta
  </a>
</div>
<% } %>

<header class="header">
  <div class="header-left">
    <button class="icon-btn" id="menuBtn" onclick="toggleDrawer()">
      <span class="material-symbols-outlined">menu</span>
    </button>
    <a href="/" class="header-logo">
      <div class="logo-icon">
        <svg width="32" height="32" viewBox="0 0 40 40" fill="none">
          <rect width="40" height="40" rx="8" fill="#1a73e8"/>
          <text x="20" y="27" text-anchor="middle" fill="white" font-size="22" font-family="Arial" font-weight="bold">C</text>
        </svg>
      </div>
      <span class="header-title">Clases</span>
    </a>
  </div>
  <div class="header-center">
    <% if (school) { %><span class="header-school-name"><%= school.name %></span><% } %>
  </div>
  <div class="header-right">
    <% if (typeof user !== 'undefined' && user) { %>
      <% if (_activeTheme) { %>
      <button id="themeModeBtn" onclick="toggleTheme()" title="Activar/Desactivar Temática"
        style="display:flex;align-items:center;justify-content:center;width:36px;height:36px;border-radius:50%;border:2.5px solid #74acdf;background:#fff;cursor:pointer;font-size:20px;line-height:1;padding:0;box-shadow:0 1px 4px rgba(116,172,223,.5)">
        <%= ({
          'mundial-argentina':'🇦🇷','halloween':'🎃','navidad':'🎄',
          'dia-bandera':'🏳️','independencia':'🎆','dia-maestro':'📚',
          'primavera':'🌸','carnaval':'🎭'
        })[_activeTheme.slug] || '🎨' %>
      </button>
      <% } %>
      <button class="icon-btn" id="darkModeBtn" onclick="toggleDarkMode()" title="Cambiar tema">
        <span class="material-symbols-outlined">dark_mode</span>
      </button>
      <span class="user-role role-badge role-<%= user.role %>"><%= roleNames[user.role] || user.role %></span>
      <button class="icon-btn" onclick="toggleUserMenu()" title="Menú de usuario">
        <% if (user.avatar) { %>
          <div class="avatar avatar-img"><img src="<%= user.avatar %>" alt="<%= user.name %>"></div>
        <% } else { %>
          <div class="avatar"><%= user.name.charAt(0).toUpperCase() %></div>
        <% } %>
      </button>
      <div class="user-menu" id="userMenu">
        <div class="user-menu-header">
          <% if (user.avatar) { %>
            <div class="avatar-huge avatar-img"><img src="<%= user.avatar %>" alt="<%= user.name %>"></div>
          <% } else { %>
            <div class="avatar-huge"><%= user.name.charAt(0).toUpperCase() %></div>
          <% } %>
          <div class="user-menu-info">
            <div class="user-menu-name"><%= user.name %></div>
            <div class="user-menu-email"><%= user.email %></div>
            <span class="role-badge role-<%= user.role %>" style="margin-top:8px"><%= roleNames[user.role] || user.role %></span>
          </div>
        </div>
        <div class="user-menu-divider"></div>
        <% if (impersonating) { %>
          <a href="/exit-impersonate" class="user-menu-item">
            <span class="material-symbols-outlined">swap_horiz</span>
            Volver a mi cuenta (<%= impersonating.name %>)
          </a>
          <div class="user-menu-divider"></div>
        <% } %>
        <button class="user-menu-item" onclick="logout()">
          <span class="material-symbols-outlined">logout</span>
          Cerrar sesión
        </button>
      </div>
    <% } %>
  </div>
</header>

<nav class="drawer" id="drawer">
  <div class="drawer-overlay" onclick="toggleDrawer()"></div>
  <div class="drawer-content">
    <div class="drawer-header">
      <button class="icon-btn" onclick="toggleDrawer()">
        <span class="material-symbols-outlined">menu</span>
      </button>
      <span class="drawer-title">Classroom</span>
    </div>
    <div class="drawer-body">
      <a href="/" class="drawer-item">
        <span class="material-symbols-outlined">school</span>
        <span>Clases</span>
      </a>
      <% if (typeof user !== 'undefined' && user && user.role !== 'superadmin') { %>
        <a href="/courses/profile" class="drawer-item">
          <span class="material-symbols-outlined">account_circle</span>
          <span>Mi perfil</span>
        </a>
      <% } %>
      <% if (typeof user !== 'undefined' && user && user.role === 'student') { %>
        <a href="/activities/my-pending" class="drawer-item">
          <span class="material-symbols-outlined">pending_actions</span>
          <span>Mis pendientes</span>
        </a>
      <% } %>
      <% if (typeof user !== 'undefined' && user && user.role === 'admin' && !impersonating) { %>
        <a href="/admin" class="drawer-item">
          <span class="material-symbols-outlined">admin_panel_settings</span>
          <span>Administración</span>
        </a>
      <% } %>
      <% if (typeof user !== 'undefined' && user && user.role === 'superadmin' && !impersonating) { %>
        <a href="/superadmin" class="drawer-item">
          <span class="material-symbols-outlined">manage_accounts</span>
          <span>Superadministración</span>
        </a>
      <% } %>
      <% if (impersonating) { %>
        <a href="/exit-impersonate" class="drawer-item" style="color:#ea8600">
          <span class="material-symbols-outlined">swap_horiz</span>
          <span>Salir de vista</span>
        </a>
      <% } %>
    </div>
  </div>
</nav>
