<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin - Classroom</title>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,0..200" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 40 40'><rect width='40' height='40' rx='8' fill='%231a73e8'/><text x='20' y='28' text-anchor='middle' fill='white' font-size='24' font-family='Arial' font-weight='bold'>C</text></svg>">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/header') %>

  <main class="main-content">
    <%- include('../partials/admin-nav', { activePage: 'dashboard' }) %>

    <div class="dashboard-topbar">
      <div>
        <h2>Panel de Administración</h2>
        <p style="color:var(--text-secondary);font-size:14px;margin-top:4px">Gestión general del sistema</p>
      </div>
      <div class="dashboard-actions">
        <a href="/admin/users/create" class="btn btn-outline">
          <span class="material-symbols-outlined">person_add</span>
          Nuevo usuario
        </a>
        <a href="/admin/subjects/create" class="btn btn-primary">
          <span class="material-symbols-outlined">add</span>
          Nueva materia
        </a>
      </div>
    </div>

    <div class="stats-grid">
      <div class="stat-card" style="--stat-color:#1a73e8">
        <div class="stat-icon"><span class="material-symbols-outlined">people</span></div>
        <div class="stat-info">
          <span class="stat-value"><%= userCount %></span>
          <span class="stat-label">Usuarios totales</span>
        </div>
      </div>
      <div class="stat-card" style="--stat-color:#34a853">
        <div class="stat-icon"><span class="material-symbols-outlined">school</span></div>
        <div class="stat-info">
          <span class="stat-value"><%= courseCount %></span>
          <span class="stat-label">Cursos totales</span>
        </div>
      </div>
      <div class="stat-card" style="--stat-color:#ea8600">
        <div class="stat-icon"><span class="material-symbols-outlined">badge</span></div>
        <div class="stat-info">
          <span class="stat-value"><%= teacherCount %></span>
          <span class="stat-label">Profesores</span>
        </div>
      </div>
      <div class="stat-card" style="--stat-color:#9334e6">
        <div class="stat-icon"><span class="material-symbols-outlined">group</span></div>
        <div class="stat-info">
          <span class="stat-value"><%= studentCount %></span>
          <span class="stat-label">Alumnos</span>
        </div>
      </div>
      <div class="stat-card" style="--stat-color:#0d7377">
        <div class="stat-icon"><span class="material-symbols-outlined">menu_book</span></div>
        <div class="stat-info">
          <span class="stat-value"><%= subjectCount %></span>
          <span class="stat-label">Materias</span>
        </div>
      </div>
    </div>

    <div class="admin-section-cards">
      <a href="/admin/users" class="admin-section-card">
        <div class="admin-section-card-icon" style="background:#e8f0fe">
          <span class="material-symbols-outlined" style="color:#1a73e8">people</span>
        </div>
        <div class="admin-section-card-info">
          <h3>Usuarios</h3>
          <p><%= userCount %> usuario(s) registrado(s)</p>
        </div>
        <span class="material-symbols-outlined admin-section-card-arrow">chevron_right</span>
      </a>
      <a href="/admin/subjects" class="admin-section-card">
        <div class="admin-section-card-icon" style="background:#e6f4ea">
          <span class="material-symbols-outlined" style="color:#34a853">menu_book</span>
        </div>
        <div class="admin-section-card-info">
          <h3>Materias</h3>
          <p><%= subjectCount %> materia(s) registrada(s)</p>
        </div>
        <span class="material-symbols-outlined admin-section-card-arrow">chevron_right</span>
      </a>
    </div>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>
