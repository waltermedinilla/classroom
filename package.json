{
  "name": "classroom-escuela",
  "version": "1.0.0",
  "description": "Google Classroom clone with Node.js, Express, MongoDB and vanilla JS",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "prod": "pm2 start ecosystem.config.js",
    "prod:stop": "pm2 stop classroom",
    "prod:restart": "pm2 restart classroom",
    "prod:logs": "pm2 logs classroom",
    "prod:status": "pm2 status",
    "cleanup": "node cleanup-files.js",
    "cleanup:dry": "node cleanup-files.js --dry-run"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "connect-mongo": "^4.6.0",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.0.3",
    "ejs": "^3.1.8",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.17.3",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^6.8.0",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.0",
    "winston": "^3.19.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^2.0.20"
  }
}
