<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Temas - Administración</title>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,0..200&display=swap" />
  <link rel="icon" type="image/png" href="/favicon.png">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .theme-card { border:1px solid var(--border); border-radius:12px; overflow:hidden; margin-bottom:16px; }
    .theme-card-header { padding:16px 20px; display:flex; align-items:center; gap:14px; }
    .theme-card.offered  { border-color:#ea8600; }
    .theme-card.accepted { border-color:#137333; }
    .theme-card.rejected { opacity:.6; }
    .status-badge { font-size:11px; font-weight:700; padding:3px 10px; border-radius:12px; }
    .status-offered  { background:#fef3e2; color:#ea8600; }
    .status-accepted { background:#e6f4ea; color:#137333; }
    .status-rejected { background:#fce8e6; color:#ea4335; }
    .feature-chip { font-size:11px; background:var(--surface-variant,#f1f3f4); padding:3px 10px; border-radius:12px; display:inline-flex; align-items:center; gap:4px; }
    .feature-chip.disabled { opacity:.4; text-decoration:line-through; }
    .empty-state { text-align:center; padding:60px 20px; color:var(--text-secondary); }
  </style>
</head>
<body>
  <%- include('../partials/header') %>
  <main class="main-content">
    <%- include('../partials/admin-nav') %>

    <div class="section-header" style="margin-bottom:24px">
      <span class="material-symbols-outlined section-icon" style="color:#9334e6">palette</span>
      <h2 style="margin:0">Configuración Anual de Temas</h2>
    </div>

    <%
      const offered  = school.themes?.filter(t => t.status === 'offered')  || [];
      const accepted = school.themes?.filter(t => t.status === 'accepted') || [];
      const rejected = school.themes?.filter(t => t.status === 'rejected') || [];
    %>

    <% if (!school.themes?.length) { %>
    <div class="empty-state">
      <span class="material-symbols-outlined" style="font-size:56px;color:var(--border)">palette</span>
      <p style="margin:12px 0 0;font-size:15px">No hay temas asignados a esta escuela aún.</p>
      <p style="margin:4px 0 0;font-size:13px">El superadministrador puede ofrecer temas desde su panel.</p>
    </div>
    <% } %>

    <% if (offered.length) { %>
    <h3 style="font-size:14px;color:#ea8600;margin:0 0 10px;display:flex;align-items:center;gap:6px">
      <span class="material-symbols-outlined" style="font-size:18px">notifications_active</span>
      Temas pendientes (<%= offered.length %>)
    </h3>
    <% offered.forEach(t => { const themeInfo = THEMES[t.slug]; if (!themeInfo) return; %>
    <div class="theme-card offered">
      <div class="theme-card-header">
        <span style="font-size:32px"><%= themeInfo.preview %></span>
        <div style="flex:1">
          <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
            <strong style="font-size:15px"><%= themeInfo.name %></strong>
            <span class="status-badge status-offered">Ofrecido</span>
          </div>
          <p style="margin:2px 0;font-size:12px;color:var(--text-secondary)"><%= themeInfo.description %></p>
          <span style="font-size:11px;color:var(--text-secondary)">📅 <%= t.startDate || themeInfo.defaultStart %> → <%= t.endDate || themeInfo.defaultEnd %></span>
        </div>
        <div style="display:flex;flex-direction:column;gap:8px;flex-shrink:0">
          <button class="btn btn-primary" style="font-size:13px" onclick="respond('<%= t.slug %>','accept')">
            <span class="material-symbols-outlined" style="font-size:16px">check</span> Aceptar
          </button>
          <button class="btn btn-outline" style="font-size:13px;border-color:#ea4335;color:#ea4335" onclick="respond('<%= t.slug %>','reject')">
            <span class="material-symbols-outlined" style="font-size:16px">close</span> Rechazar
          </button>
        </div>
      </div>
      <div style="padding:12px 20px;border-top:1px solid var(--border);display:flex;gap:8px;flex-wrap:wrap">
        <% Object.entries(themeInfo.features).forEach(([fkey, feat]) => { %>
          <% const enabled = t.config?.[fkey]?.enabled !== false; %>
          <span class="feature-chip <%= enabled ? '' : 'disabled' %>">
            <%= enabled ? '✓' : '✗' %> <%= feat.label %>
          </span>
        <% }) %>
      </div>
    </div>
    <% }) %>
    <% } %>

    <% if (accepted.length) { %>
    <h3 style="font-size:14px;color:#137333;margin:16px 0 10px;display:flex;align-items:center;gap:6px">
      <span class="material-symbols-outlined" style="font-size:18px">check_circle</span>
      Temas activos (<%= accepted.length %>)
    </h3>
    <% accepted.forEach(t => { const themeInfo = THEMES[t.slug]; if (!themeInfo) return; %>
    <div class="theme-card accepted">
      <div class="theme-card-header">
        <span style="font-size:32px"><%= themeInfo.preview %></span>
        <div style="flex:1">
          <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
            <strong style="font-size:15px"><%= themeInfo.name %></strong>
            <span class="status-badge status-accepted">Activo</span>
          </div>
          <p style="margin:2px 0;font-size:12px;color:var(--text-secondary)"><%= themeInfo.description %></p>
          <span style="font-size:11px;color:var(--text-secondary)">📅 <%= t.startDate || themeInfo.defaultStart %> → <%= t.endDate || themeInfo.defaultEnd %></span>
        </div>
      </div>
      <div style="padding:12px 20px;border-top:1px solid var(--border);display:flex;gap:8px;flex-wrap:wrap">
        <% Object.entries(themeInfo.features).forEach(([fkey, feat]) => { %>
          <% const enabled = t.config?.[fkey]?.enabled !== false; %>
          <span class="feature-chip <%= enabled ? '' : 'disabled' %>">
            <%= enabled ? '✓' : '✗' %> <%= feat.label %>
          </span>
        <% }) %>
      </div>
      <div style="padding:10px 20px;border-top:1px solid var(--border);font-size:12px;color:var(--text-secondary)">
        Los usuarios ven este tema automáticamente cuando la fecha está en el rango indicado. El superadmin ajusta la configuración.
      </div>
    </div>
    <% }) %>
    <% } %>

    <% if (rejected.length) { %>
    <h3 style="font-size:14px;color:#999;margin:16px 0 10px">Temas rechazados</h3>
    <% rejected.forEach(t => { const themeInfo = THEMES[t.slug]; if (!themeInfo) return; %>
    <div class="theme-card rejected">
      <div class="theme-card-header">
        <span style="font-size:28px"><%= themeInfo.preview %></span>
        <div style="flex:1">
          <div style="display:flex;align-items:center;gap:8px">
            <strong style="font-size:14px"><%= themeInfo.name %></strong>
            <span class="status-badge status-rejected">Rechazado</span>
          </div>
        </div>
        <button class="btn btn-outline" style="font-size:12px" onclick="respond('<%= t.slug %>','accept')">Reactivar</button>
      </div>
    </div>
    <% }) %>
    <% } %>

  </main>
  <%- include('../partials/footer') %>
  <script>
    async function respond(slug, action) {
      if (!confirm('¿Querés ' + (action === 'accept' ? 'aceptar' : 'rechazar') + ' este tema?')) return;
      const res = await fetch('/admin/theme/respond', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ slug, action }),
      });
      if (res.ok) location.reload();
      else alert('Error al procesar la respuesta');
    }
  </script>
</body>
</html>
