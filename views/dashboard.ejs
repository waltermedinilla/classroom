<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Clases - Classroom</title>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,0..200" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 40 40'><rect width='40' height='40' rx='8' fill='%231a73e8'/><text x='20' y='28' text-anchor='middle' fill='white' font-size='24' font-family='Arial' font-weight='bold'>C</text></svg>">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/header') %>

  <main class="main-content">
    <div class="dashboard-topbar">
      <h2>Tus clases</h2>
      <div class="dashboard-actions">
        <button class="btn btn-outline" onclick="showJoinModal()">
          <span class="material-symbols-outlined">group_add</span>
          Unirse a clase
        </button>
        <button class="btn btn-primary" onclick="showCreateModal()">
          <span class="material-symbols-outlined">add</span>
          Crear clase
        </button>
      </div>
    </div>

    <section class="section">
      <div class="section-header">
        <span class="material-symbols-outlined section-icon">star</span>
        <h3>Creadas por ti</h3>
      </div>
      <% if (createdCourses.length === 0) { %>
        <div class="empty-state">
          <div class="empty-icon">
            <span class="material-symbols-outlined">school</span>
          </div>
          <p>Aún no has creado ninguna clase</p>
        </div>
      <% } %>
      <div class="course-grid">
        <% createdCourses.forEach(course => { %>
          <a href="/courses/<%= course._id %>" class="course-card" style="--card-color: #1a73e8">
            <div class="card-banner">
              <div class="card-banner-content">
                <h4><%= course.name %></h4>
                <p><%= course.owner.name %></p>
              </div>
            </div>
            <div class="card-body">
              <% if (course.section) { %>
                <div class="card-info">
                  <span class="material-symbols-outlined card-info-icon">chrome_reader_mode</span>
                  <span><%= course.section %></span>
                </div>
              <% } %>
              <% if (course.subject) { %>
                <div class="card-info">
                  <span class="material-symbols-outlined card-info-icon">book</span>
                  <span><%= course.subject %></span>
                </div>
              <% } %>
            </div>
            <div class="card-footer">
              <div class="card-code">
                <span class="material-symbols-outlined">vpn_key</span>
                <span><%= course.code %></span>
              </div>
              <span class="card-owner-badge">Creador</span>
            </div>
          </a>
        <% }) %>
      </div>
    </section>

    <section class="section">
      <div class="section-header">
        <span class="material-symbols-outlined section-icon">group</span>
        <h3>Unidas por ti</h3>
      </div>
      <% if (joinedCourses.length === 0) { %>
        <div class="empty-state">
          <div class="empty-icon">
            <span class="material-symbols-outlined">group_add</span>
          </div>
          <p>Aún no te has unido a ninguna clase</p>
        </div>
      <% } %>
      <div class="course-grid">
        <% joinedCourses.forEach(course => { %>
          <a href="/courses/<%= course._id %>" class="course-card" style="--card-color: #34a853">
            <div class="card-banner">
              <div class="card-banner-content">
                <h4><%= course.name %></h4>
                <p><%= course.owner.name %></p>
              </div>
            </div>
            <div class="card-body">
              <% if (course.section) { %>
                <div class="card-info">
                  <span class="material-symbols-outlined card-info-icon">chrome_reader_mode</span>
                  <span><%= course.section %></span>
                </div>
              <% } %>
            </div>
            <div class="card-footer">
              <div class="card-teacher">
                <span class="material-symbols-outlined">person</span>
                <span><%= course.owner.name %></span>
              </div>
              <span class="card-student-badge">Estudiante</span>
            </div>
          </a>
        <% }) %>
      </div>
    </section>
  </main>

  <div class="modal-overlay" id="createModal">
    <div class="modal">
      <div class="modal-header">
        <div class="modal-header-left">
          <span class="material-symbols-outlined modal-header-icon">add_circle</span>
          <h3>Crear clase</h3>
        </div>
        <button class="icon-btn" onclick="hideCreateModal()">
          <span class="material-symbols-outlined">close</span>
        </button>
      </div>
      <div class="modal-body">
        <div class="warning-banner">
          <span class="material-symbols-outlined warning-icon">info</span>
          <span><strong>Aviso:</strong> Este es un clon con fines educativos.</span>
        </div>
        <form id="createForm">
          <div class="input-group">
            <span class="material-symbols-outlined input-icon">badge</span>
            <input type="text" id="className" placeholder="Nombre de la clase (obligatorio)" required>
          </div>
          <div class="input-group">
            <span class="material-symbols-outlined input-icon">chrome_reader_mode</span>
            <input type="text" id="section" placeholder="Sección">
          </div>
          <div class="input-group">
            <span class="material-symbols-outlined input-icon">book</span>
            <input type="text" id="subject" placeholder="Materia">
          </div>
          <div class="input-group">
            <span class="material-symbols-outlined input-icon">meeting_room</span>
            <input type="text" id="room" placeholder="Salón">
          </div>
          <div class="form-error" id="createError"></div>
          <button type="submit" class="btn btn-primary btn-full">
            <span class="material-symbols-outlined">check</span>
            Crear
          </button>
        </form>
      </div>
    </div>
  </div>

  <div class="modal-overlay" id="joinModal">
    <div class="modal">
      <div class="modal-header">
        <div class="modal-header-left">
          <span class="material-symbols-outlined modal-header-icon">group_add</span>
          <h3>Unirse a clase</h3>
        </div>
        <button class="icon-btn" onclick="hideJoinModal()">
          <span class="material-symbols-outlined">close</span>
        </button>
      </div>
      <div class="modal-body">
        <p class="modal-desc">Pide el código de la clase a tu profesor e ingrésalo aquí.</p>
        <form id="joinForm">
          <div class="input-group">
            <span class="material-symbols-outlined input-icon">vpn_key</span>
            <input type="text" id="classCode" placeholder="Código de la clase" required>
          </div>
          <div class="form-error" id="joinError"></div>
          <button type="submit" class="btn btn-primary btn-full">
            <span class="material-symbols-outlined">arrow_forward</span>
            Unirse
          </button>
        </form>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>
  <script src="/js/dashboard.js"></script>
</body>
</html>
