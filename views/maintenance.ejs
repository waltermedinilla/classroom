<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mantenimiento - Classroom</title>
  <link rel="icon" type="image/png" href="/favicon.png">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-body">
  <div class="auth-container">
    <div class="auth-card" style="text-align:center">
      <div class="auth-logo">
        <svg viewBox="0 0 390 135" xmlns="http://www.w3.org/2000/svg" style="width:100%;display:block;margin-bottom:6px">
          <defs>
            <clipPath id="lc"><circle cx="68" cy="68" r="60"/></clipPath>
            <linearGradient id="tg" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" style="stop-color:#1a3a6b"/>
              <stop offset="100%" style="stop-color:#74acdf"/>
            </linearGradient>
          </defs>
          <circle cx="68" cy="68" r="65" fill="#74acdf" opacity="0.25"/>
          <circle cx="68" cy="68" r="60" fill="none" stroke="#74acdf" stroke-width="3"/>
          <image href="/Logo.jpg" x="8" y="8" width="120" height="120" clip-path="url(#lc)" preserveAspectRatio="xMidYMid slice"/>
          <text x="152" y="54" font-family="'Segoe UI',Arial,sans-serif" font-size="35" font-weight="800" fill="url(#tg)">San José</text>
          <text x="152" y="96" font-family="'Segoe UI',Arial,sans-serif" font-size="35" font-weight="800" fill="url(#tg)">Conecta</text>
          <line x1="152" y1="108" x2="378" y2="108" stroke="#74acdf" stroke-width="3" stroke-linecap="round" opacity="0.6"/>
        </svg>
      </div>

      <div style="font-size:52px;line-height:1;margin:10px 0">🛠️</div>
      <h2 style="margin:0 0 10px">Estamos en mantenimiento</h2>
      <p class="auth-subtitle" style="margin:0 0 6px"><%= message %></p>
      <% if (eta) { %>
        <p style="font-size:13px;color:var(--text-secondary,#666);margin:0 0 18px">Tiempo estimado: <strong><%= eta %></strong></p>
      <% } %>

      <button class="btn btn-primary" style="width:100%;margin-top:10px" onclick="location.reload()">
        Reintentar
      </button>
    </div>
  </div>
</body>
</html>
