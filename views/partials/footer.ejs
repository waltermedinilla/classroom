  <% const _canSuggest = !!user; %>
  <% if (_canSuggest) { %>
  <button class="fab" id="fabSuggest" onclick="document.getElementById('suggestionModal').style.display='flex'" title="Enviar sugerencia">
    <span class="material-symbols-outlined">lightbulb</span>
  </button>

  <div id="suggestionModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:2000;align-items:center;justify-content:center">
    <div style="background:var(--surface);border-radius:12px;padding:32px;width:100%;max-width:460px;margin:16px;box-shadow:0 8px 32px rgba(0,0,0,.2)">
      <h3 style="margin:0 0 6px;font-size:18px;display:flex;align-items:center;gap:8px">
        <span class="material-symbols-outlined" style="color:#fbbc04">lightbulb</span>
        Enviar sugerencia
      </h3>
      <p style="font-size:13px;color:var(--text-secondary);margin:0 0 20px">Tu sugerencia será revisada por el equipo.</p>
      <div id="suggestError" style="display:none;background:#fce8e6;color:#c5221f;padding:10px 14px;border-radius:8px;font-size:14px;margin-bottom:14px"></div>
      <div id="suggestOk" style="display:none;background:#e6f4ea;color:#137333;padding:10px 14px;border-radius:8px;font-size:14px;margin-bottom:14px"></div>
      <textarea id="suggestionText" rows="4" placeholder="Describí tu sugerencia…" maxlength="1000"
        style="width:100%;padding:10px 14px;border:1px solid var(--border);border-radius:8px;font-size:14px;resize:vertical;font-family:inherit;background:var(--surface);color:var(--text);box-sizing:border-box;outline:none"></textarea>
      <div style="display:flex;justify-content:space-between;align-items:center;margin-top:6px;margin-bottom:20px">
        <span id="suggestCount" style="font-size:12px;color:var(--text-hint)">0 / 1000</span>
      </div>
      <div style="display:flex;gap:10px;justify-content:flex-end">
        <button class="btn btn-outline" onclick="closeSuggestModal()">Cancelar</button>
        <button class="btn btn-primary" id="saveSuggestBtn" onclick="submitSuggestion()">Enviar</button>
      </div>
    </div>
  </div>

  <script>
    document.getElementById('suggestionText').addEventListener('input', function () {
      document.getElementById('suggestCount').textContent = this.value.length + ' / 1000';
    });

    function closeSuggestModal() {
      document.getElementById('suggestionModal').style.display = 'none';
      document.getElementById('suggestionText').value = '';
      document.getElementById('suggestCount').textContent = '0 / 1000';
      document.getElementById('suggestError').style.display = 'none';
      document.getElementById('suggestOk').style.display = 'none';
    }

    async function submitSuggestion() {
      const errBox  = document.getElementById('suggestError');
      const okBox   = document.getElementById('suggestOk');
      const btn     = document.getElementById('saveSuggestBtn');
      const text    = document.getElementById('suggestionText').value.trim();
      errBox.style.display = 'none';
      okBox.style.display  = 'none';

      if (!text) {
        errBox.textContent = 'Escribí tu sugerencia antes de enviar';
        errBox.style.display = 'block';
        return;
      }

      btn.disabled = true;
      btn.innerHTML = '<span class="upload-spinner" style="width:16px;height:16px;border-width:2px;display:inline-block;vertical-align:middle;margin-right:6px"></span>Enviando…';

      try {
        const res  = await fetch('/suggestions', {
          method:  'POST',
          headers: { 'Content-Type': 'application/json' },
          body:    JSON.stringify({ text }),
        });
        const data = await res.json();
        if (res.ok) {
          okBox.textContent = '¡Sugerencia enviada! Gracias.';
          okBox.style.display = 'block';
          document.getElementById('suggestionText').value = '';
          document.getElementById('suggestCount').textContent = '0 / 1000';
          setTimeout(closeSuggestModal, 1500);
        } else {
          errBox.textContent = data.error || 'Error al enviar';
          errBox.style.display = 'block';
        }
      } catch {
        errBox.textContent = 'Error de conexión. Intentá de nuevo.';
        errBox.style.display = 'block';
      } finally {
        btn.disabled = false;
        btn.innerHTML = 'Enviar';
      }
    }
  </script>

  <!-- Bandeja "Mis sugerencias" — historial propio + respuestas del equipo -->
  <div id="inboxModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:2000;align-items:center;justify-content:center" onclick="if(event.target===this)closeInboxModal()">
    <div style="background:var(--surface);border-radius:12px;width:100%;max-width:520px;margin:16px;max-height:80vh;display:flex;flex-direction:column;box-shadow:0 8px 32px rgba(0,0,0,.2)">
      <div style="padding:20px 24px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;flex-shrink:0">
        <h3 style="margin:0;font-size:18px;display:flex;align-items:center;gap:8px">
          <span class="material-symbols-outlined" style="color:#1a73e8">mail</span>
          Mis sugerencias
        </h3>
        <button class="icon-btn" onclick="closeInboxModal()" title="Cerrar">
          <span class="material-symbols-outlined">close</span>
        </button>
      </div>
      <div id="inboxBody" style="overflow-y:auto;flex:1"></div>
    </div>
  </div>

  <script>
    function escapeHtml(str) {
      var div = document.createElement('div');
      div.textContent = str == null ? '' : String(str);
      return div.innerHTML;
    }

    function updateInboxBadge(count) {
      var badge = document.getElementById('inboxBadge');
      var icon  = document.querySelector('#inboxBtn .material-symbols-outlined');
      if (icon) icon.textContent = count > 0 ? 'mark_email_unread' : 'mail';
      if (!badge) return;
      if (count > 0) {
        badge.textContent = count > 9 ? '9+' : count;
        badge.style.display = 'flex';
      } else {
        badge.style.display = 'none';
      }
    }

    async function openInboxModal() {
      document.getElementById('inboxModal').style.display = 'flex';
      var body = document.getElementById('inboxBody');
      body.innerHTML = '<div style="padding:40px 16px;text-align:center;color:var(--text-secondary)">Cargando…</div>';
      try {
        var res  = await fetch('/suggestions/mine');
        var data = await res.json();
        renderInbox(data.suggestions || []);
      } catch {
        body.innerHTML = '<div style="padding:40px 16px;text-align:center;color:var(--danger)">Error al cargar tus sugerencias</div>';
      }
    }

    function closeInboxModal() {
      document.getElementById('inboxModal').style.display = 'none';
    }

    var INBOX_STATUS = {
      pending:  { label: 'Pendiente',  bg: '#fff3e0', color: '#ea8600' },
      reviewed: { label: 'Revisada',   bg: '#e8eaed', color: '#5f6368' },
      answered: { label: 'Respondida', bg: '#e6f4ea', color: '#137333' },
    };

    function renderInbox(suggestions) {
      var body = document.getElementById('inboxBody');
      if (!suggestions.length) {
        body.innerHTML = '<div class="empty-state" style="padding:40px 16px">' +
          '<div class="empty-icon"><span class="material-symbols-outlined">mail</span></div>' +
          '<p>Todavía no enviaste ninguna sugerencia.</p></div>';
        return;
      }

      body.innerHTML = suggestions.map(function (s) {
        var st   = INBOX_STATUS[s.status] || INBOX_STATUS.pending;
        var date = new Date(s.createdAt).toLocaleDateString('es-AR', { day: 'numeric', month: 'short', year: 'numeric' });
        var responseHtml = '';
        if (s.status === 'answered' && s.response) {
          var rdate = s.respondedAt
            ? new Date(s.respondedAt).toLocaleDateString('es-AR', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' })
            : '';
          responseHtml = '' +
            '<div style="margin-top:10px;padding:12px 14px;background:var(--bg);border-radius:8px;border-left:3px solid #1a73e8">' +
              '<div style="font-size:11px;font-weight:600;color:#1a73e8;margin-bottom:4px;display:flex;align-items:center;gap:4px">' +
                '<span class="material-symbols-outlined" style="font-size:14px">reply</span>' +
                'Respuesta del equipo' + (rdate ? ' · ' + rdate : '') +
              '</div>' +
              '<div style="font-size:13px;color:var(--text);white-space:pre-wrap">' + escapeHtml(s.response) + '</div>' +
            '</div>';
        }
        return '' +
          '<div style="padding:14px 24px;border-bottom:1px solid var(--border)">' +
            '<div style="display:flex;justify-content:space-between;align-items:flex-start;gap:10px">' +
              '<div style="font-size:13px;color:var(--text);white-space:pre-wrap;flex:1">' + escapeHtml(s.text) + '</div>' +
              '<span style="flex-shrink:0;font-size:10px;font-weight:600;padding:2px 8px;border-radius:10px;background:' + st.bg + ';color:' + st.color + '">' + st.label + '</span>' +
            '</div>' +
            '<div style="font-size:11px;color:var(--text-hint);margin-top:4px">' + date + '</div>' +
            responseHtml +
          '</div>';
      }).join('');

      // Marca como leídas las respondidas no leídas (fire-and-forget) y baja el badge ya mismo.
      // No esperamos la respuesta del server: si falla, el peor caso es que el badge vuelva
      // a aparecer en el próximo pageview (se recalcula server-side), nunca queda "colgado".
      var unread = suggestions.filter(function (s) { return s.status === 'answered' && !s.readByUser; });
      if (unread.length) {
        unread.forEach(function (s) {
          fetch('/suggestions/mine/' + s._id + '/read', { method: 'POST' }).catch(function () {});
        });
        updateInboxBadge(0);
      }
    }

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') closeInboxModal();
    });
  </script>
  <% } %>

  <script>
    function toggleDrawer() {
      document.getElementById('drawer').classList.toggle('open');
    }
    var path = window.location.pathname;
    document.querySelectorAll('.drawer-item').forEach(function(item) {
      var href = item.getAttribute('href');
      if ((href === '/' && path !== '/admin' && !path.startsWith('/admin')) || (href !== '/' && path.startsWith(href))) {
        item.classList.add('active');
      }
    });
    function toggleUserMenu() {
      document.getElementById('userMenu').classList.toggle('show');
    }
    document.addEventListener('click', function(e) {
      if (!e.target.closest('.header-right')) {
        document.getElementById('userMenu')?.classList.remove('show');
      }
    });
    async function logout() {
      if (!confirm('¿Cerrar sesión?')) return;
      await fetch('/logout', { method: 'POST' });
      window.location.href = '/login';
    }

    function _applyTheme(theme) {
      document.documentElement.setAttribute('data-theme', theme);
      var icon = document.querySelector('#darkModeBtn .material-symbols-outlined');
      if (icon) icon.textContent = theme === 'dark' ? 'light_mode' : 'dark_mode';
    }
    function toggleDarkMode() {
      var current = document.documentElement.getAttribute('data-theme') || 'light';
      var next = current === 'dark' ? 'light' : 'dark';
      localStorage.setItem('theme', next);
      _applyTheme(next);
    }
    _applyTheme(localStorage.getItem('theme') || 'light');
  </script>
</body>
</html>
