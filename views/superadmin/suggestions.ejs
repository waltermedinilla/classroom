<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sugerencias - Superadmin</title>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,0..200&display=swap" />
  <link rel="icon" type="image/png" href="/favicon.png">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/header') %>
  <main class="main-content">
    <%- include('../partials/superadmin-nav') %>

    <div class="section-header" style="margin-bottom:24px">
      <span class="material-symbols-outlined section-icon" style="color:#fbbc04">lightbulb</span>
      <h2 style="margin:0">Sugerencias</h2>
      <% if (pendingCount > 0) { %>
        <span class="badge-count" style="background:#ea4335;color:#fff;font-size:12px;padding:2px 10px;border-radius:12px;font-weight:600;margin-left:8px"><%= pendingCount %> pendiente<%= pendingCount !== 1 ? 's' : '' %></span>
      <% } %>
    </div>

    <!-- Filtros -->
    <div style="display:flex;gap:8px;margin-bottom:24px;flex-wrap:wrap">
      <a href="/superadmin/suggestions?status=all"
        class="btn <%= status === 'all' ? 'btn-primary' : 'btn-outline' %>">Todas</a>
      <a href="/superadmin/suggestions?status=pending"
        class="btn <%= status === 'pending' ? 'btn-primary' : 'btn-outline' %>">Pendientes</a>
      <a href="/superadmin/suggestions?status=reviewed"
        class="btn <%= status === 'reviewed' ? 'btn-primary' : 'btn-outline' %>">Revisadas</a>
      <a href="/superadmin/suggestions?status=answered"
        class="btn <%= status === 'answered' ? 'btn-primary' : 'btn-outline' %>">Respondidas</a>
    </div>

    <% if (suggestions.length === 0) { %>
      <div class="empty-state">
        <div class="empty-icon"><span class="material-symbols-outlined">lightbulb</span></div>
        <p>No hay sugerencias<%= status !== 'all' ? ' en esta categoría' : '' %>.</p>
      </div>
    <% } else { %>
      <%
        const statusBadges = {
          pending:  { label: 'PENDIENTE',  bg: '#fff3e0', color: '#ea8600' },
          reviewed: { label: 'REVISADA',   bg: '#e8eaed', color: '#5f6368' },
          answered: { label: 'RESPONDIDA', bg: '#e6f4ea', color: '#137333' },
        };
      %>
      <div style="display:flex;flex-direction:column;gap:14px">
        <% suggestions.forEach(s => { %>
          <% const sb = statusBadges[s.status] || statusBadges.pending; %>
          <div class="suggestion-card" id="scard-<%= s._id %>" data-status="<%= s.status %>">
            <div class="suggestion-header">
              <div style="display:flex;align-items:center;gap:10px;flex:1;min-width:0">
                <div class="avatar" style="width:36px;height:36px;font-size:15px;flex-shrink:0;background:<%= s.user?.role === 'admin' ? '#ea4335' : s.user?.role === 'directivo' ? '#9334e6' : s.user?.role === 'preceptor' ? '#ea8600' : '#0d7377' %>">
                  <%= s.user?.name?.charAt(0).toUpperCase() || '?' %>
                </div>
                <div style="min-width:0">
                  <div style="font-weight:500;font-size:14px"><%= s.user?.name || 'Usuario eliminado' %></div>
                  <div style="font-size:12px;color:var(--text-secondary);display:flex;align-items:center;gap:6px;flex-wrap:wrap">
                    <span class="role-badge role-<%= s.user?.role %>" style="font-size:11px;padding:1px 8px"><%= roleNames[s.user?.role] || s.user?.role %></span>
                    <% if (s.school) { %>
                      <span style="display:flex;align-items:center;gap:4px">
                        <span style="width:8px;height:8px;border-radius:50%;background:<%= s.school.color %>;display:inline-block"></span>
                        <%= s.school.name %>
                      </span>
                    <% } %>
                    <span><%= new Date(s.createdAt).toLocaleDateString('es-ES', { day:'numeric', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' }) %></span>
                  </div>
                </div>
              </div>
              <div style="display:flex;align-items:center;gap:8px;flex-shrink:0">
                <span id="statusBadge-<%= s._id %>" style="background:<%= sb.bg %>;color:<%= sb.color %>;font-size:11px;padding:3px 10px;border-radius:12px;font-weight:600"><%= sb.label %></span>
                <% if (s.status === 'pending') { %>
                  <button class="btn btn-outline" style="font-size:12px;padding:4px 12px" onclick="markReviewed('<%= s._id %>')">
                    <span class="material-symbols-outlined" style="font-size:15px">check_circle</span>
                    Marcar revisada
                  </button>
                <% } %>
                <% if (s.status !== 'answered') { %>
                  <button class="btn btn-primary" style="font-size:12px;padding:4px 12px" onclick="toggleRespond('<%= s._id %>')">
                    <span class="material-symbols-outlined" style="font-size:15px">reply</span>
                    Responder
                  </button>
                <% } %>
                <button class="icon-btn" title="Eliminar" onclick="deleteSuggestion('<%= s._id %>')">
                  <span class="material-symbols-outlined" style="font-size:18px;color:var(--text-hint)">delete</span>
                </button>
              </div>
            </div>
            <p class="suggestion-text"><%= s.text %></p>

            <% if (s.status === 'answered') { %>
              <div style="margin-top:4px;padding:12px 14px;background:var(--bg);border-radius:8px;border-left:3px solid #1a73e8" id="responseDisplay-<%= s._id %>">
                <div style="font-size:11px;font-weight:600;color:#1a73e8;margin-bottom:4px;display:flex;justify-content:space-between;align-items:center;gap:8px">
                  <span style="display:flex;align-items:center;gap:4px">
                    <span class="material-symbols-outlined" style="font-size:14px">reply</span>
                    Tu respuesta<% if (s.respondedAt) { %> · <%= new Date(s.respondedAt).toLocaleDateString('es-ES', { day:'numeric', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' }) %><% } %>
                  </span>
                  <button class="icon-btn" style="width:24px;height:24px" title="Editar respuesta" onclick="toggleRespond('<%= s._id %>', true)">
                    <span class="material-symbols-outlined" style="font-size:15px">edit</span>
                  </button>
                </div>
                <div style="font-size:13px;color:var(--text);white-space:pre-wrap" id="responseText-<%= s._id %>"><%= s.response %></div>
              </div>
            <% } %>

            <div class="suggest-respond-area" id="respond-<%= s._id %>" style="display:none;margin-top:12px">
              <textarea class="respond-textarea" id="respondText-<%= s._id %>" rows="3" maxlength="1000"
                placeholder="Escribí tu respuesta…"
                style="width:100%;padding:10px 14px;border:1px solid var(--border);border-radius:8px;font-size:13px;resize:vertical;font-family:inherit;background:var(--surface);color:var(--text);box-sizing:border-box;outline:none"></textarea>
              <div id="respondError-<%= s._id %>" style="display:none;color:var(--danger);font-size:12px;margin-top:4px"></div>
              <div style="display:flex;gap:8px;justify-content:flex-end;margin-top:8px">
                <button class="btn btn-outline" style="font-size:12px;padding:6px 14px" onclick="toggleRespond('<%= s._id %>')">Cancelar</button>
                <button class="btn btn-primary" style="font-size:12px;padding:6px 14px" id="respondBtn-<%= s._id %>" onclick="submitResponse('<%= s._id %>')">Enviar respuesta</button>
              </div>
            </div>
          </div>
        <% }) %>
      </div>

      <%
        function buildUrl(overrides) {
          const p = {};
          if (status && status !== 'all') p.status = status;
          Object.assign(p, overrides);
          return '/superadmin/suggestions?' + Object.entries(p).map(([k,v]) => k+'='+encodeURIComponent(v)).join('&');
        }
        let pagesToShow = [];
        if (totalPages <= 7) {
          for (let i = 1; i <= totalPages; i++) pagesToShow.push(i);
        } else {
          pagesToShow.push(1);
          if (page > 3) pagesToShow.push('...');
          for (let i = Math.max(2, page-2); i <= Math.min(totalPages-1, page+2); i++) pagesToShow.push(i);
          if (page < totalPages-2) pagesToShow.push('...');
          pagesToShow.push(totalPages);
        }
      %>
      <% if (totalPages > 1) { %>
        <div class="pagination">
          <% if (page > 1) { %>
            <a href="<%= buildUrl({page: page-1}) %>" class="page-btn" title="Anterior">
              <span class="material-symbols-outlined" style="font-size:18px">chevron_left</span>
            </a>
          <% } %>
          <% pagesToShow.forEach(p => { %>
            <% if (p === '...') { %>
              <span class="page-ellipsis">…</span>
            <% } else { %>
              <a href="<%= buildUrl({page: p}) %>" class="page-btn <%= p === page ? 'active' : '' %>"><%= p %></a>
            <% } %>
          <% }) %>
          <% if (page < totalPages) { %>
            <a href="<%= buildUrl({page: page+1}) %>" class="page-btn" title="Siguiente">
              <span class="material-symbols-outlined" style="font-size:18px">chevron_right</span>
            </a>
          <% } %>
        </div>
      <% } %>
    <% } %>
  </main>

  <%- include('../partials/footer') %>
  <script>
    async function markReviewed(id) {
      const res = await fetch(`/superadmin/suggestions/${id}/reviewed`, { method: 'POST' });
      if (res.ok) {
        const card = document.getElementById('scard-' + id);
        card.dataset.status = 'reviewed';
        card.querySelector('.btn.btn-outline').remove();
        document.getElementById('statusBadge-' + id).outerHTML =
          `<span id="statusBadge-${id}" style="background:#e8eaed;color:#5f6368;font-size:11px;padding:3px 10px;border-radius:12px;font-weight:600">REVISADA</span>`;
      }
    }

    async function deleteSuggestion(id) {
      if (!confirm('¿Eliminar esta sugerencia?')) return;
      const res = await fetch(`/superadmin/suggestions/${id}`, { method: 'DELETE' });
      if (res.ok) document.getElementById('scard-' + id).remove();
    }

    // Abre/cierra el área de respuesta. isEdit=true precarga el texto actual (editar
    // una respuesta ya enviada); false arranca vacío (responder por primera vez).
    function toggleRespond(id, isEdit) {
      const area    = document.getElementById('respond-' + id);
      const showing = area.style.display !== 'none';
      if (showing) {
        area.style.display = 'none';
        return;
      }
      if (isEdit) {
        const current = document.getElementById('responseText-' + id);
        document.getElementById('respondText-' + id).value = current ? current.textContent : '';
      }
      area.style.display = 'block';
      document.getElementById('respondText-' + id).focus();
    }

    async function submitResponse(id) {
      const textarea = document.getElementById('respondText-' + id);
      const errBox    = document.getElementById('respondError-' + id);
      const btn       = document.getElementById('respondBtn-' + id);
      const text      = textarea.value.trim();
      errBox.style.display = 'none';

      if (!text) {
        errBox.textContent = 'Escribí una respuesta antes de enviar';
        errBox.style.display = 'block';
        return;
      }

      const card   = document.getElementById('scard-' + id);
      const isEdit = card.dataset.status === 'answered';

      btn.disabled = true;
      btn.textContent = 'Enviando…';
      try {
        const res  = await fetch(`/superadmin/suggestions/${id}/respond`, {
          method:  'POST',
          headers: { 'Content-Type': 'application/json' },
          body:    JSON.stringify({ text, isEdit }),
        });
        const data = await res.json();
        if (res.ok) {
          // Recarga la página: más simple y robusto que replicar en JS todos los
          // estados posibles (pending/reviewed/answered) que puede tomar la tarjeta.
          location.reload();
        } else {
          errBox.textContent = data.error || 'Error al enviar la respuesta';
          errBox.style.display = 'block';
          btn.disabled = false;
          btn.textContent = 'Enviar respuesta';
        }
      } catch {
        errBox.textContent = 'Error de conexión. Intentá de nuevo.';
        errBox.style.display = 'block';
        btn.disabled = false;
        btn.textContent = 'Enviar respuesta';
      }
    }
  </script>
</body>
</html>
