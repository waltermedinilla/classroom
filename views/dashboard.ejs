<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Clases - Classroom</title>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,0..200&display=swap" />
  <link rel="icon" type="image/png" href="/favicon.png">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/header') %>

  <main class="main-content">
    <div class="dashboard-topbar">
      <h2>Tus clases</h2>
      <div class="dashboard-actions">
        <button class="btn btn-outline" onclick="showJoinModal()">
          <span class="material-symbols-outlined">group_add</span>
          Unirse a clase
        </button>
        <% if (user.role !== 'student') { %>
        <button class="btn btn-primary" onclick="showCreateModal()">
          <span class="material-symbols-outlined">add</span>
          Crear clase
        </button>
        <% } %>
      </div>
    </div>

    <% if (typeof pendingSummary !== 'undefined' && pendingSummary) { %>
    <div class="pending-band">
      <span class="material-symbols-outlined">assignment_late</span>
      <span>
        Tenés <strong><%= pendingSummary.total %></strong>
        tarea<%= pendingSummary.total !== 1 ? 's' : '' %> pendiente<%= pendingSummary.total !== 1 ? 's' : '' %>
        <% if (pendingSummary.dueToday > 0) { %>
          &nbsp;·&nbsp; <strong class="pending-band-urgent"><%= pendingSummary.dueToday %> vence<%= pendingSummary.dueToday !== 1 ? 'n' : '' %> hoy</strong>
        <% } %>
      </span>
      <a href="/activities/my-pending" class="pending-band-link">Ver todas</a>
    </div>
    <% } %>

    <section class="section">
      <% if (courses.length === 0) { %>
        <div class="empty-state">
          <div class="empty-icon"><span class="material-symbols-outlined">school</span></div>
          <% if (user.role === 'student') { %>
            <p><span class="badge-unmatriculated" style="font-size:13px;padding:4px 12px">(Sin Matricular)</span></p>
            <p style="margin-top:10px;color:var(--text-secondary);font-size:14px">No estás matriculado en ningún curso. Pedile el código de clase a tu docente.</p>
          <% } else { %>
            <p>Aún no tenés clases. Creá una o unite con un código.</p>
          <% } %>
        </div>
      <% } %>
      <div class="course-grid">
        <% courses.forEach(course => { %>
          <%
            const subtitle = course.division?.name || '';
            const _h = course.header || {};
            const _defaultColor = course.isOwner ? '#1a73e8' : '#34a853';
            const _cardColor = _h.color || _defaultColor;
            let _bannerStyle = '';
            if (_h.image) {
              _bannerStyle = `background: linear-gradient(${_cardColor}bb,${_cardColor}bb), url('${_h.image}') center/cover no-repeat;`;
            } else if (_h.color && _h.color2) {
              _bannerStyle = `background: linear-gradient(135deg, ${_h.color}, ${_h.color2});`;
            }
          %>
          <a href="/courses/<%= course._id %>" class="course-card" style="--card-color: <%= _cardColor %>">
            <div class="card-banner"<% if (_bannerStyle) { %> style="<%= _bannerStyle %>"<% } %>>
              <div class="card-banner-content">
                <h4><%= course.name %></h4>
                <% if (subtitle) { %><p><%= subtitle %></p><% } %>
              </div>
              <div class="card-banner-deco">
                <span class="material-symbols-outlined"><%= course.isOwner ? 'school' : 'menu_book' %></span>
              </div>
            </div>
            <div class="card-body">
              <% if (course.isOwner) { %>
                <div class="card-stat">
                  <span class="material-symbols-outlined">group</span>
                  <span><%= course.students.length %> alumno<%= course.students.length !== 1 ? 's' : '' %></span>
                </div>
              <% } else { %>
                <div class="card-stat">
                  <div class="avatar" style="width:26px;height:26px;font-size:11px;background:#1a73e8"><%= course.owner.name.charAt(0).toUpperCase() %></div>
                  <span><%= course.owner.name %></span>
                </div>
              <% } %>
            </div>
            <div class="card-footer">
              <div class="card-footer-icons">
                <button class="icon-btn card-icon-btn" title="Novedades"
                  onclick="event.preventDefault();event.stopPropagation();window.location.href='/courses/<%= course._id %>'">
                  <span class="material-symbols-outlined">campaign</span>
                </button>
                <button class="icon-btn card-icon-btn" title="Actividades"
                  onclick="event.preventDefault();event.stopPropagation();window.location.href='/courses/<%= course._id %>'">
                  <span class="material-symbols-outlined">assignment</span>
                </button>
              </div>
              <button class="icon-btn card-icon-btn" title="Copiar código de clase"
                onclick="event.preventDefault();event.stopPropagation();copyCode('<%= course.code %>')">
                <span class="material-symbols-outlined">more_vert</span>
              </button>
            </div>
          </a>
        <% }) %>
      </div>
    </section>
  </main>

  <div class="modal-overlay" id="createModal">
    <div class="modal">
      <div class="modal-header">
        <div class="modal-header-left">
          <span class="material-symbols-outlined modal-header-icon">add_circle</span>
          <h3>Crear clase</h3>
        </div>
        <button class="icon-btn" onclick="hideCreateModal()">
          <span class="material-symbols-outlined">close</span>
        </button>
      </div>
      <div class="modal-body">
        <div class="warning-banner">
          <span class="material-symbols-outlined warning-icon">info</span>
          <span><strong>Aviso:</strong> Este es un clon con fines educativos.</span>
        </div>
        <form id="createForm">
          <div class="input-group">
            <span class="material-symbols-outlined input-icon">badge</span>
            <input type="text" id="className" placeholder="Nombre de la materia (obligatorio)" required>
          </div>
          <div class="input-group">
            <span class="material-symbols-outlined input-icon">class</span>
            <select id="divisionId" required style="flex:1;border:none;background:transparent;font-size:14px;color:var(--text-primary);outline:none;padding:0">
              <option value="">Cargando cursos...</option>
            </select>
          </div>
          <div class="input-group">
            <span class="material-symbols-outlined input-icon">meeting_room</span>
            <input type="text" id="room" placeholder="Salón (opcional)">
          </div>
          <div class="form-error" id="createError"></div>
          <button type="submit" class="btn btn-primary btn-full">
            <span class="material-symbols-outlined">check</span>
            Crear
          </button>
        </form>
      </div>
    </div>
  </div>

  <div class="modal-overlay" id="joinModal">
    <div class="modal">
      <div class="modal-header">
        <div class="modal-header-left">
          <span class="material-symbols-outlined modal-header-icon">group_add</span>
          <h3>Unirse a clase</h3>
        </div>
        <button class="icon-btn" onclick="hideJoinModal()">
          <span class="material-symbols-outlined">close</span>
        </button>
      </div>
      <div class="modal-body">
        <p class="modal-desc">Pide el código de la clase a tu profesor e ingrésalo aquí.</p>
        <form id="joinForm">
          <div class="input-group">
            <span class="material-symbols-outlined input-icon">vpn_key</span>
            <input type="text" id="classCode" placeholder="Código de la clase" required>
          </div>
          <div class="form-error" id="joinError"></div>
          <button type="submit" class="btn btn-primary btn-full">
            <span class="material-symbols-outlined">arrow_forward</span>
            Unirse
          </button>
        </form>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>
  <script src="/js/dashboard.js"></script>
</body>
</html>
