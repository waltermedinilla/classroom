<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Usuarios - Admin - Classroom</title>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,0..200&display=swap" />
  <link rel="icon" type="image/png" href="/favicon.png">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/header') %>

  <main class="main-content">
    <%- include('../partials/admin-nav', { activePage: 'users' }) %>

    <div class="dashboard-topbar">
      <div>
        <h2>Usuarios</h2>
        <p style="color:var(--text-secondary);font-size:14px;margin-top:4px"><%= total %> usuario(s) encontrado(s)</p>
      </div>
      <div class="dashboard-actions">
        <button class="btn btn-primary" onclick="openUserModal()">
          <span class="material-symbols-outlined">person_add</span>
          Nuevo usuario
        </button>
      </div>
    </div>

    <div class="filter-bar">
      <form method="GET" action="/admin/users" class="filter-form">
        <div class="input-group" style="flex:1">
          <span class="material-symbols-outlined input-icon">search</span>
          <input type="text" name="search" placeholder="Buscar por nombre o email..." value="<%= search %>">
        </div>
        <div class="input-group" style="width:200px">
          <span class="material-symbols-outlined input-icon">filter_list</span>
          <select name="role" class="select-input" onchange="this.form.submit()">
            <option value="">Todos los roles</option>
            <option value="admin" <%= currentRole === 'admin' ? 'selected' : '' %>>Administrador</option>
            <option value="directivo" <%= currentRole === 'directivo' ? 'selected' : '' %>>Directivo</option>
            <option value="teacher" <%= currentRole === 'teacher' ? 'selected' : '' %>>Docente</option>
            <option value="preceptor" <%= currentRole === 'preceptor' ? 'selected' : '' %>>Preceptor</option>
            <option value="soe" <%= currentRole === 'soe' ? 'selected' : '' %>>SOE</option>
            <option value="student" <%= currentRole === 'student' ? 'selected' : '' %>>Alumno</option>
          </select>
        </div>
        <button type="submit" class="btn btn-outline">Buscar</button>
      </form>
    </div>

    <div class="users-table-card">
      <% if (users.length === 0) { %>
        <div class="empty-state">
          <div class="empty-icon"><span class="material-symbols-outlined">search_off</span></div>
          <p>No se encontraron usuarios</p>
        </div>
      <% } else { %>
        <table class="users-table">
          <thead>
            <tr>
              <th>DNI</th>
              <th>Usuario</th>
              <th>Email</th>
              <th>Rol</th>
              <th>Registro</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach(u => { %>
              <tr>
                <td style="font-family:monospace;font-size:13px"><%= u.dni || '—' %></td>
                <td>
                  <div style="display:flex;align-items:center;gap:12px">
                    <div class="avatar" style="width:32px;height:32px;font-size:14px;opacity:<%= u.active === false ? 0.4 : 1 %>"><%= u.name.charAt(0).toUpperCase() %></div>
                    <div>
                      <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap">
                        <span style="font-weight:500;color:<%= u.active === false ? 'var(--text-hint)' : 'inherit' %>"><%= u.name %></span>
                        <% if (u.role === 'student' && !enrolledMap[u._id.toString()]) { %>
                          <span class="badge-unmatriculated">(Sin Matricular)</span>
                        <% } %>
                      </div>
                      <% if (u.active === false) { %>
                        <span style="display:block;font-size:11px;color:#ea4335;font-weight:600;letter-spacing:.3px">DESHABILITADO</span>
                      <% } %>
                    </div>
                  </div>
                </td>
                <td class="td-email"><%= u.email %></td>
                <td><span class="role-badge role-<%= u.role %>"><%= roleNames[u.role] || u.role %></span></td>
                <td class="td-date"><%= new Date(u.createdAt).toLocaleDateString('es-ES', { day:'numeric', month:'short', year:'numeric' }) %></td>
                <td>
                  <a href="/admin/users/<%= u._id %>" class="btn btn-outline" style="padding:6px 16px;font-size:13px">Ver perfil</a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>
    <%- include('../partials/pagination') %>
  </main>

  <!-- Modal: Nuevo usuario -->
  <div class="modal-overlay" id="userModal">
    <div class="modal">
      <div class="modal-header">
        <div class="modal-header-left">
          <span class="material-symbols-outlined modal-header-icon">person_add</span>
          <h3>Nuevo usuario</h3>
        </div>
        <button class="icon-btn" onclick="closeUserModal()">
          <span class="material-symbols-outlined">close</span>
        </button>
      </div>
      <div class="modal-body">
        <form id="createUserForm">
          <div class="input-group">
            <span class="material-symbols-outlined input-icon">badge</span>
            <input type="text" id="uName" placeholder="Nombre completo" required>
          </div>
          <div class="input-group" style="margin-top:16px">
            <span class="material-symbols-outlined input-icon">fingerprint</span>
            <input type="text" id="uDni" placeholder="DNI (opcional)">
          </div>
          <div class="input-group" style="margin-top:16px">
            <span class="material-symbols-outlined input-icon">email</span>
            <input type="email" id="uEmail" placeholder="Correo electrónico" required>
          </div>
          <div class="input-group" style="margin-top:16px">
            <span class="material-symbols-outlined input-icon">lock</span>
            <input type="password" id="uPassword" placeholder="Contraseña (mín. 6 caracteres)" required>
          </div>
          <div class="input-group" style="margin-top:16px">
            <span class="material-symbols-outlined input-icon">badge</span>
            <select id="uRole" class="select-input" onchange="toggleUserDivisionField()">
              <option value="student">Alumno</option>
              <option value="teacher">Docente</option>
              <option value="preceptor">Preceptor</option>
              <option value="soe">SOE</option>
              <option value="directivo">Directivo</option>
              <option value="admin">Administrador</option>
            </select>
          </div>
          <!-- Combobox condicional: solo visible cuando el rol es "Alumno". Si se elige un
               Curso, el backend inscribe al alumno en todas sus materias con joinedAt = ahora
               (ver POST /admin/users/create) — las tareas ya vencidas antes de esa fecha no
               le figurarán, salvo que no tengan fecha límite o el docente habilite tardías. -->
          <div class="input-group" id="uDivisionField" style="margin-top:16px<%= divisions && divisions.length ? '' : ';display:none' %>">
            <span class="material-symbols-outlined input-icon">school</span>
            <select id="uDivisionId" class="select-input">
              <option value="">— Sin curso (opcional) —</option>
              <% (divisions || []).forEach(d => { %>
                <option value="<%= d._id %>"><%= d.name %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-error" id="userFormError" style="margin-top:16px"></div>
          <div id="userFormSuccess" style="display:none;margin-top:16px;padding:10px 14px;background:#e6f4ea;color:#137333;border-radius:8px;font-size:13px"></div>
          <button type="submit" class="btn btn-primary btn-full" style="margin-top:20px">
            <span class="material-symbols-outlined">check</span>
            Crear usuario
          </button>
        </form>
      </div>
    </div>
  </div>

  <%- include('../partials/footer') %>
  <script>
    function openUserModal() {
      document.getElementById('userModal').classList.add('show');
      document.body.style.overflow = 'hidden';
      toggleUserDivisionField();
    }
    function closeUserModal() {
      document.getElementById('userModal').classList.remove('show');
      document.body.style.overflow = '';
      document.getElementById('createUserForm').reset();
      document.getElementById('userFormError').classList.remove('show');
      document.getElementById('userFormSuccess').style.display = 'none';
      toggleUserDivisionField();
    }
    document.getElementById('userModal').addEventListener('click', function (e) {
      if (e.target === this) closeUserModal();
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') closeUserModal();
    });

    // Muestra el combobox de Curso solo cuando el rol es Alumno. Si no hay divisiones
    // cargadas en la escuela del admin, queda oculto siempre (nada que elegir).
    function toggleUserDivisionField() {
      const role  = document.getElementById('uRole').value;
      const field = document.getElementById('uDivisionField');
      const hasDivisions = field.querySelectorAll('option').length > 1; // > 1: siempre está la opción vacía
      field.style.display = (role === 'student' && hasDivisions) ? '' : 'none';
      if (role !== 'student') document.getElementById('uDivisionId').value = '';
    }

    document.getElementById('createUserForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const errorEl   = document.getElementById('userFormError');
      const successEl = document.getElementById('userFormSuccess');
      errorEl.classList.remove('show');
      successEl.style.display = 'none';
      const btn = e.target.querySelector('button[type="submit"]');
      btn.disabled = true;
      btn.innerHTML = '<span class="material-symbols-outlined">hourglass_top</span> Creando...';
      const res = await fetch('/admin/users/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: document.getElementById('uName').value,
          dni: document.getElementById('uDni').value.trim() || undefined,
          email: document.getElementById('uEmail').value,
          password: document.getElementById('uPassword').value,
          role: document.getElementById('uRole').value,
          divisionId: document.getElementById('uDivisionId').value || undefined,
        }),
      });
      const data = await res.json();
      btn.disabled = false;
      btn.innerHTML = '<span class="material-symbols-outlined">check</span> Crear usuario';
      if (!res.ok) {
        errorEl.textContent = data.error;
        errorEl.classList.add('show');
        return;
      }
      if (data.existedAlready) {
        // No se creó nadie: el DNI ya correspondía a un alumno existente. Se lo
        // matriculó en las materias que le faltaban del Curso elegido (si eligió uno).
        successEl.textContent = data.enrolledIn > 0
          ? `Ya existía un alumno con ese DNI (${data.user.name}). Se lo inscribió en ${data.enrolledIn} materia${data.enrolledIn === 1 ? '' : 's'} que le faltaba${data.enrolledIn === 1 ? '' : 'n'} del curso.`
          : `Ya existía un alumno con ese DNI (${data.user.name}). Ya estaba matriculado en todas las materias de este curso.`;
        successEl.style.display = 'block';
        setTimeout(() => { window.location.href = '/admin/users/' + data.user._id; }, 1600);
      } else if (data.enrolledIn > 0) {
        successEl.textContent = `Usuario creado e inscripto en ${data.enrolledIn} materia${data.enrolledIn === 1 ? '' : 's'} del curso.`;
        successEl.style.display = 'block';
        setTimeout(() => { window.location.href = '/admin/users/' + data.user._id; }, 900);
      } else {
        window.location.href = '/admin/users/' + data.user._id;
      }
    });

    // Soporte para abrir el modal directo por link (ej: desde el dashboard admin)
    if (new URLSearchParams(window.location.search).get('create') === '1') {
      openUserModal();
    }
  </script>
</body>
</html>
