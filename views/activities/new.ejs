<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nueva tarea — <%= course.name %></title>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,0..200" />
  <link rel="icon" type="image/png" href="/favicon.png">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="creator-page">

  <!-- Header fijo -->
  <header class="creator-header">
    <div class="creator-header-left">
      <a href="/courses/<%= course._id %>" class="icon-btn" title="Cancelar">
        <span class="material-symbols-outlined">close</span>
      </a>
      <span class="material-symbols-outlined creator-header-icon">assignment</span>
      <span class="creator-header-title">Tarea</span>
    </div>
    <div class="creator-header-right">
      <div id="globalError" class="creator-error-inline" style="display:none"></div>
      <button class="btn btn-primary" id="createBtn" onclick="submitActivity()">
        Crear tarea
      </button>
    </div>
  </header>

  <!-- Cuerpo de dos columnas -->
  <div class="creator-body">

    <!-- Columna principal -->
    <div class="creator-main">

      <!-- Card: Título + Instrucciones -->
      <div class="creator-card">
        <div class="creator-title-field">
          <input type="text" id="actTitle" class="creator-title-input" placeholder="Título">
          <span class="creator-required">* Obligatorio</span>
        </div>
        <div class="creator-divider"></div>
        <div class="creator-editor-wrap">
          <div
            id="actInstructions"
            class="creator-editor"
            contenteditable="true"
            data-placeholder="Instrucciones (opcional)"
          ></div>
          <div class="creator-toolbar">
            <button type="button" class="toolbar-btn" onclick="fmt('bold')" title="Negrita"><strong>B</strong></button>
            <button type="button" class="toolbar-btn" onclick="fmt('italic')" title="Cursiva"><em>I</em></button>
            <button type="button" class="toolbar-btn" onclick="fmt('underline')" title="Subrayado"><u>U</u></button>
            <button type="button" class="toolbar-btn" onclick="fmt('insertUnorderedList')" title="Lista">
              <span class="material-symbols-outlined">format_list_bulleted</span>
            </button>
            <button type="button" class="toolbar-btn" onclick="fmt('strikeThrough')" title="Tachado">
              <s>S</s>
            </button>
          </div>
        </div>
      </div>

      <!-- Card: Adjuntar -->
      <div class="creator-card">
        <div class="creator-card-section-title">Adjuntar</div>
        <div class="creator-att-row">
          <label class="creator-att-btn" title="Subir archivo (PDF, Word, Excel)">
            <input type="file" id="fileInput" accept=".pdf,.doc,.docx,.xls,.xlsx" multiple hidden>
            <div class="creator-att-circle">
              <span class="material-symbols-outlined">upload</span>
            </div>
            <span>Subir</span>
          </label>
          <button type="button" class="creator-att-btn" onclick="openLinkDialog()" title="Agregar enlace">
            <div class="creator-att-circle">
              <span class="material-symbols-outlined">link</span>
            </div>
            <span>Enlace</span>
          </button>
        </div>

        <!-- Input de enlace -->
        <div id="linkDialog" class="creator-link-dialog" style="display:none">
          <div class="input-group" style="flex:1">
            <span class="material-symbols-outlined input-icon">link</span>
            <input type="url" id="linkUrlInput" placeholder="https://...">
          </div>
          <button class="btn btn-primary" style="padding:0 18px;height:46px" onclick="addLink()">Agregar</button>
          <button class="icon-btn" onclick="closeLinkDialog()" title="Cancelar">
            <span class="material-symbols-outlined">close</span>
          </button>
        </div>

        <!-- Previsualización de adjuntos -->
        <div id="attPreviews" class="att-preview-grid" style="padding:0 24px 20px;margin-top:4px"></div>
      </div>

    </div>

    <!-- Sidebar -->
    <aside class="creator-sidebar">

      <div class="sidebar-card">
        <div class="sidebar-label">Para</div>
        <div class="sidebar-course-name"><%= course.name %></div>
        <% if (course.division?.name) { %>
          <div class="sidebar-course-sub"><%= course.division.name %></div>
        <% } %>
      </div>

      <div class="sidebar-card">
        <div class="sidebar-label">Asignar a</div>
        <div class="sidebar-chip">
          <span class="material-symbols-outlined">group</span>
          Todos los alumnos
        </div>
      </div>

      <div class="sidebar-card">
        <div class="sidebar-label">Puntos</div>
        <div class="sidebar-input-wrap">
          <input type="number" id="sPoints" class="sidebar-input" value="10" min="0" max="10" placeholder="Sin puntos">
        </div>
      </div>

      <div class="sidebar-card">
        <div class="sidebar-label">Disponible desde</div>
        <div class="sidebar-input-wrap">
          <input type="datetime-local" id="sAvailableFrom" class="sidebar-input">
        </div>
        <div class="sidebar-hint">Por defecto: ahora mismo</div>
      </div>

      <div class="sidebar-card">
        <div class="sidebar-label">Fecha de entrega</div>
        <div class="sidebar-input-wrap">
          <input type="datetime-local" id="sDueDate" class="sidebar-input">
        </div>
        <div class="sidebar-hint">Vacío = sin fecha límite</div>
      </div>

    </aside>
  </div>

  <!-- Modal de error de adjunto -->
  <div id="uploadErrModal" class="upl-modal-overlay" style="display:none" onclick="if(event.target===this)closeUploadErrModal()">
    <div class="upl-modal">
      <div class="upl-modal-icon">
        <span class="material-symbols-outlined">error</span>
      </div>
      <p class="upl-modal-title" id="uplModalTitle"></p>
      <p class="upl-modal-msg"   id="uplModalMsg"></p>
      <button class="btn btn-primary" onclick="closeUploadErrModal()">Entendido</button>
    </div>
  </div>

  <script>
    const COURSE_ID = '<%= course._id %>';
    const EXT_COLOR = { PDF: '#ea4335', DOC: '#1a73e8', DOCX: '#1a73e8', XLS: '#34a853', XLSX: '#34a853' };

    // Precarga "Disponible desde" con ahora y "Fecha de entrega" con una semana después
    (function () {
      const toLocal = d => new Date(d.getTime() - d.getTimezoneOffset() * 60000)
        .toISOString().slice(0, 16);

      const now = new Date();
      now.setSeconds(0, 0);
      document.getElementById('sAvailableFrom').value = toLocal(now);

      const nextWeek = new Date(now);
      nextWeek.setDate(nextWeek.getDate() + 7);
      document.getElementById('sDueDate').value = toLocal(nextWeek);
    })();

    // { uid: { url, name, mime } } — solo archivos ya subidos al servidor
    const actUploadedFiles = {};
    let actLinks = [];
    let pendingUploads = 0;

    /* ─── Rich text ─── */
    function fmt(cmd) {
      document.getElementById('actInstructions').focus();
      document.execCommand(cmd, false, null);
    }

    /* ─── Botón crear: refleja si hay subidas en curso ─── */
    function syncCreateBtn() {
      const btn = document.getElementById('createBtn');
      if (pendingUploads > 0) {
        btn.disabled = true;
        btn.textContent = pendingUploads === 1 ? 'Subiendo archivo...' : `Subiendo ${pendingUploads} archivos...`;
      } else {
        btn.disabled = false;
        btn.textContent = 'Crear tarea';
      }
    }

    /* ─── Modal de error ─── */
    function showUploadErrModal(title, msg) {
      document.getElementById('uplModalTitle').textContent = title;
      document.getElementById('uplModalMsg').textContent   = msg;
      document.getElementById('uploadErrModal').style.display = 'flex';
    }
    function closeUploadErrModal() {
      document.getElementById('uploadErrModal').style.display = 'none';
    }
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') closeUploadErrModal();
    });

    /* ─── Adjuntos: archivos — sube de inmediato al seleccionar ─── */
    const ALLOWED_EXTS   = ['pdf', 'doc', 'docx', 'xls', 'xlsx'];
    const MAX_SIZE_BYTES = 50 * 1024 * 1024; // 50 MB

    document.getElementById('fileInput').addEventListener('change', function () {
      Array.from(this.files).forEach(uploadFile);
      this.value = '';
    });

    function uploadFile(file) {
      // Validación cliente: tipo de archivo
      const extRaw = file.name.split('.').pop().toLowerCase();
      if (!ALLOWED_EXTS.includes(extRaw)) {
        showUploadErrModal(
          'Tipo de archivo no permitido',
          `"${file.name}" no es un formato aceptado.\nPodés subir archivos PDF, Word (.doc, .docx) o Excel (.xls, .xlsx).`
        );
        return;
      }
      // Validación cliente: tamaño
      if (file.size > MAX_SIZE_BYTES) {
        const mb = (file.size / 1024 / 1024).toFixed(1);
        showUploadErrModal(
          'Archivo demasiado grande',
          `"${file.name}" pesa ${mb} MB. El máximo permitido es 50 MB.`
        );
        return;
      }

      const uid   = Date.now() + '-' + Math.random().toString(36).slice(2);
      const ext   = extRaw.toUpperCase();
      const color = EXT_COLOR[ext] || '#5f6368';

      // Agrega la tarjeta con barra de progreso
      const grid = document.getElementById('attPreviews');
      const card = document.createElement('div');
      card.className = 'att-preview-card';
      card.id = 'ucard-' + uid;
      card.innerHTML = `
        <div class="att-preview-thumb" style="background:${color}">
          <span class="att-preview-ext">${ext}</span>
        </div>
        <div class="att-upload-progress-wrap">
          <div class="att-upload-bar" style="width:0%"></div>
        </div>
        <div class="att-upload-status">0%</div>`;
      grid.appendChild(card);

      pendingUploads++;
      syncCreateBtn();

      const fd = new FormData();
      fd.append('file', file);

      const xhr = new XMLHttpRequest();

      xhr.upload.onprogress = (e) => {
        if (!e.lengthComputable) return;
        const pct = Math.round((e.loaded / e.total) * 100);
        const c = document.getElementById('ucard-' + uid);
        if (!c) return;
        c.querySelector('.att-upload-bar').style.width = pct + '%';
        c.querySelector('.att-upload-status').textContent = pct < 100 ? pct + '%' : 'Procesando...';
      };

      xhr.onload = () => {
        pendingUploads--;
        const c = document.getElementById('ucard-' + uid);
        if (!c) { syncCreateBtn(); return; }

        let data = null;
        try { data = JSON.parse(xhr.responseText); } catch {}

        if ((xhr.status === 200 || xhr.status === 201) && data?.url) {
          actUploadedFiles[uid] = { url: data.url, name: data.name, mime: data.mime };
          c.innerHTML = `
            <div class="att-preview-thumb" style="background:${color}">
              <span class="att-preview-ext">${ext}</span>
            </div>
            <div class="att-preview-name" title="${escHtml(file.name)}">${escHtml(file.name)}</div>
            <button class="att-preview-remove" onclick="removeUploadedFile('${uid}')" title="Quitar">
              <span class="material-symbols-outlined">close</span>
            </button>`;
        } else {
          if (c) c.remove();
          const msg = data?.error || `Error inesperado (${xhr.status})`;
          showUploadErrModal('No se pudo subir el archivo', msg);
        }
        syncCreateBtn();
      };

      xhr.onerror = () => {
        pendingUploads--;
        const c = document.getElementById('ucard-' + uid);
        if (c) c.remove();
        showUploadErrModal('Error de conexión', 'No se pudo conectar con el servidor. Verificá tu conexión e intentá de nuevo.');
        syncCreateBtn();
      };

      xhr.open('POST', '/activities/upload-attachment?courseId=' + encodeURIComponent(COURSE_ID));
      xhr.setRequestHeader('Accept', 'application/json');
      xhr.send(fd);
    }

    function removeUploadedFile(uid) {
      delete actUploadedFiles[uid];
      const c = document.getElementById('ucard-' + uid);
      if (c) c.remove();
    }

    function escHtml(s) {
      return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    /* ─── Adjuntos: enlace ─── */
    function openLinkDialog() {
      document.getElementById('linkDialog').style.display = 'flex';
      document.getElementById('linkUrlInput').focus();
    }
    function closeLinkDialog() {
      document.getElementById('linkDialog').style.display = 'none';
      document.getElementById('linkUrlInput').value = '';
    }
    document.getElementById('linkUrlInput').addEventListener('keydown', e => {
      if (e.key === 'Enter') { e.preventDefault(); addLink(); }
      if (e.key === 'Escape') closeLinkDialog();
    });
    function addLink() {
      let url = document.getElementById('linkUrlInput').value.trim();
      if (!url) return;
      if (!/^https?:\/\//i.test(url)) url = 'https://' + url;
      let domain = url;
      try { domain = new URL(url).hostname; } catch {}
      actLinks.push({ name: domain, url });
      closeLinkDialog();
      renderLinks();
    }
    function removeLink(i) { actLinks.splice(i, 1); renderLinks(); }

    function renderLinks() {
      // Solo re-renderiza los chips de links; las tarjetas de archivo las maneja el DOM directamente
      const existing = document.querySelectorAll('.att-link-card');
      existing.forEach(el => el.remove());
      const grid = document.getElementById('attPreviews');
      actLinks.forEach((l, i) => {
        const domain = l.name || l.url;
        const card = document.createElement('div');
        card.className = 'att-preview-card att-link-card';
        card.innerHTML = `
          <div class="att-preview-thumb link-thumb">
            <img src="https://www.google.com/s2/favicons?domain=${encodeURIComponent(domain)}&sz=64" width="36" height="36"
              style="border-radius:6px"
              onerror="this.outerHTML='<span class=\\'material-symbols-outlined\\' style=\\'font-size:36px;color:var(--primary)\\'>language</span>'">
          </div>
          <div class="att-preview-name" title="${escHtml(l.url)}">${escHtml(domain)}</div>
          <button class="att-preview-remove" onclick="removeLink(${i})" title="Quitar">
            <span class="material-symbols-outlined">close</span>
          </button>`;
        grid.appendChild(card);
      });
    }

    /* ─── Enviar ─── */
    async function submitActivity() {
      const title = document.getElementById('actTitle').value.trim();
      const errEl = document.getElementById('globalError');

      if (!title) {
        errEl.textContent = 'El título es obligatorio';
        errEl.style.display = 'block';
        document.getElementById('actTitle').focus();
        return;
      }
      if (pendingUploads > 0) {
        errEl.textContent = 'Esperá a que terminen de subirse los archivos';
        errEl.style.display = 'block';
        return;
      }
      errEl.style.display = 'none';

      const btn = document.getElementById('createBtn');
      btn.disabled = true;
      btn.textContent = 'Creando...';

      const fd = new FormData();
      fd.append('courseId', COURSE_ID);
      fd.append('title', title);
      fd.append('description', document.getElementById('actInstructions').innerText.trim());
      fd.append('points', document.getElementById('sPoints').value || '');
      fd.append('dueDate', document.getElementById('sDueDate').value || '');
      fd.append('availableFrom', document.getElementById('sAvailableFrom').value || '');
      fd.append('uploadedFiles', JSON.stringify(Object.values(actUploadedFiles)));
      fd.append('links', JSON.stringify(actLinks));

      const res = await fetch('/activities/create', { method: 'POST', body: fd });
      const data = await res.json();

      btn.disabled = false;
      btn.textContent = 'Crear tarea';

      if (!res.ok) {
        errEl.textContent = data.error || 'Error al crear la tarea';
        errEl.style.display = 'block';
        return;
      }

      window.location.href = '/courses/' + COURSE_ID;
    }
  </script>
</body>
</html>
