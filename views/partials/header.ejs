<script>
  (function () {
    var t = localStorage.getItem('theme') || 'light';
    document.documentElement.setAttribute('data-theme', t);
  })();
</script>
<% if (school?.theme?.status === 'accepted' && school?.theme?.slug === 'mundial-argentina') { %>
<% const tc = school.theme.config || {}; %>
<% const confettiCount = tc.confettiCount || 30; %>
<% const speedMap = { slow: [7, 13], normal: [3, 7], fast: [1, 3] }; %>
<% const [sMin, sMax] = speedMap[tc.confettiSpeed] || speedMap.normal; %>
<style>
  <% if (tc.buttonBorder !== false) { %>
  body.theme-active .btn-primary {
    box-shadow: 0 0 0 2px #74acdf, 0 0 0 4px #fff, 0 0 0 5px #74acdf, 0 2px 8px rgba(26,115,232,.3);
  }
  <% } %>
  <% if (tc.navColors !== false) { %>
  body.theme-active .header-school-name {
    background: linear-gradient(90deg, #74acdf 0%, #fff 45%, #74acdf 100%);
    color: #1a3a6b !important;
    padding: 4px 16px;
    border-radius: 20px;
    font-weight: 600;
    border: 1.5px solid #74acdf;
  }
  <% } %>
  <% if (tc.flags !== false) { %>
  body.theme-active .arg-flag {
    position: fixed; font-size: 28px; pointer-events: none; z-index: 50; opacity: .7;
    animation: flagFloat 4s ease-in-out infinite;
  }
  body.theme-active .arg-flag:nth-child(1) { bottom: 90px; right: 100px; animation-delay: 0s; }
  body.theme-active .arg-flag:nth-child(2) { bottom: 90px; left:  24px;  animation-delay: 1s; }
  @keyframes flagFloat {
    0%,100% { transform: translateY(0) rotate(-5deg); }
    50%      { transform: translateY(-10px) rotate(5deg); }
  }
  <% } %>
  <% if (tc.confetti !== false) { %>
  @keyframes confettiFall {
    0%   { transform: translateY(-10px) rotate(0deg);   opacity: 1; }
    100% { transform: translateY(100vh) rotate(720deg); opacity: 0; }
  }
  .confetti-piece {
    position: fixed; top: -10px; border-radius: 2px;
    pointer-events: none; z-index: 9999;
    animation: confettiFall linear infinite;
  }
  <% } %>
</style>
<div class="arg-flag">🇦🇷</div>
<div class="arg-flag">🇦🇷</div>
<script>
  // Inicializa el tema según preferencia del usuario (localStorage)
  // Por defecto activo si no hay preferencia guardada
  (function () {
    var key  = 'themeActive_<%= school._id %>';
    var pref = localStorage.getItem(key);
    if (pref !== 'false') document.body.classList.add('theme-active');
  })();

  <% if (tc.confetti !== false) { %>
  (function () {
    var key = 'themeActive_<%= school._id %>';
    if (localStorage.getItem(key) === 'false') return;
    var colors = ['#74acdf','#ffffff','#74acdf','#f6b40e','#ffffff'];
    var count  = <%= confettiCount %>;
    var sMin   = <%= sMin %>, sMax = <%= sMax %>;
    for (var i = 0; i < count; i++) {
      var el = document.createElement('div');
      el.className = 'confetti-piece';
      el.style.left               = Math.random() * 100 + 'vw';
      el.style.background         = colors[Math.floor(Math.random() * colors.length)];
      el.style.animationDuration  = (Math.random() * (sMax - sMin) + sMin) + 's';
      el.style.animationDelay     = (Math.random() * 6) + 's';
      el.style.width              = (Math.random() * 6 + 5) + 'px';
      el.style.height             = (Math.random() * 6 + 5) + 'px';
      document.body.appendChild(el);
    }
  })();
  <% } %>

  function toggleTheme() {
    var key    = 'themeActive_<%= school._id %>';
    var active = document.body.classList.toggle('theme-active');
    localStorage.setItem(key, active ? 'true' : 'false');
    // Confetti: recargar para aplicar/quitar (simple y sin estado complejo)
    <% if (tc.confetti !== false) { %>
    location.reload();
    <% } %>
  }
</script>
<% } %>
<% if (impersonating) { %>
<style>
  .header { top: 44px; }
  .main-content { margin-top: 124px; }
</style>
<div class="impersonation-bar">
  <span class="material-symbols-outlined">visibility</span>
  Estás viendo como <strong><%= user ? user.name : '' %></strong>
  <span class="role-badge role-<%= user ? user.role : '' %>" style="font-size:11px;padding:2px 10px"><%= user ? (roleNames[user.role] || user.role) : '' %></span>
  <a href="/exit-impersonate" class="impersonation-exit">
    <span class="material-symbols-outlined">logout</span>
    Volver a mi cuenta
  </a>
</div>
<% } %>

<header class="header">
  <div class="header-left">
    <button class="icon-btn" id="menuBtn" onclick="toggleDrawer()">
      <span class="material-symbols-outlined">menu</span>
    </button>
    <a href="/" class="header-logo">
      <div class="logo-icon">
        <svg width="32" height="32" viewBox="0 0 40 40" fill="none">
          <rect width="40" height="40" rx="8" fill="#1a73e8"/>
          <text x="20" y="27" text-anchor="middle" fill="white" font-size="22" font-family="Arial" font-weight="bold">C</text>
        </svg>
      </div>
      <span class="header-title">Clases</span>
    </a>
  </div>
  <div class="header-center">
    <% if (school) { %><span class="header-school-name"><%= school.name %></span><% } %>
  </div>
  <div class="header-right">
    <% if (typeof user !== 'undefined' && user) { %>
      <% if (school?.theme?.status === 'accepted') { %>
      <button class="icon-btn" id="themeModeBtn" onclick="toggleTheme()" title="Activar/desactivar tema" style="font-size:20px;line-height:1">
        🇦🇷
      </button>
      <% } %>
      <button class="icon-btn" id="darkModeBtn" onclick="toggleDarkMode()" title="Cambiar tema">
        <span class="material-symbols-outlined">dark_mode</span>
      </button>
      <span class="user-role role-badge role-<%= user.role %>"><%= roleNames[user.role] || user.role %></span>
      <button class="icon-btn" onclick="toggleUserMenu()" title="Menú de usuario">
        <% if (user.avatar) { %>
          <div class="avatar avatar-img"><img src="<%= user.avatar %>" alt="<%= user.name %>"></div>
        <% } else { %>
          <div class="avatar"><%= user.name.charAt(0).toUpperCase() %></div>
        <% } %>
      </button>
      <div class="user-menu" id="userMenu">
        <div class="user-menu-header">
          <% if (user.avatar) { %>
            <div class="avatar-huge avatar-img"><img src="<%= user.avatar %>" alt="<%= user.name %>"></div>
          <% } else { %>
            <div class="avatar-huge"><%= user.name.charAt(0).toUpperCase() %></div>
          <% } %>
          <div class="user-menu-info">
            <div class="user-menu-name"><%= user.name %></div>
            <div class="user-menu-email"><%= user.email %></div>
            <span class="role-badge role-<%= user.role %>" style="margin-top:8px"><%= roleNames[user.role] || user.role %></span>
          </div>
        </div>
        <div class="user-menu-divider"></div>
        <% if (impersonating) { %>
          <a href="/exit-impersonate" class="user-menu-item">
            <span class="material-symbols-outlined">swap_horiz</span>
            Volver a mi cuenta (<%= impersonating.name %>)
          </a>
          <div class="user-menu-divider"></div>
        <% } %>
        <button class="user-menu-item" onclick="logout()">
          <span class="material-symbols-outlined">logout</span>
          Cerrar sesión
        </button>
      </div>
    <% } %>
  </div>
</header>

<nav class="drawer" id="drawer">
  <div class="drawer-overlay" onclick="toggleDrawer()"></div>
  <div class="drawer-content">
    <div class="drawer-header">
      <button class="icon-btn" onclick="toggleDrawer()">
        <span class="material-symbols-outlined">menu</span>
      </button>
      <span class="drawer-title">Classroom</span>
    </div>
    <div class="drawer-body">
      <a href="/" class="drawer-item">
        <span class="material-symbols-outlined">school</span>
        <span>Clases</span>
      </a>
      <% if (typeof user !== 'undefined' && user && user.role !== 'superadmin') { %>
        <a href="/courses/profile" class="drawer-item">
          <span class="material-symbols-outlined">account_circle</span>
          <span>Mi perfil</span>
        </a>
      <% } %>
      <% if (typeof user !== 'undefined' && user && user.role === 'student') { %>
        <a href="/activities/my-pending" class="drawer-item">
          <span class="material-symbols-outlined">pending_actions</span>
          <span>Mis pendientes</span>
        </a>
      <% } %>
      <% if (typeof user !== 'undefined' && user && user.role === 'admin' && !impersonating) { %>
        <a href="/admin" class="drawer-item">
          <span class="material-symbols-outlined">admin_panel_settings</span>
          <span>Administración</span>
        </a>
      <% } %>
      <% if (typeof user !== 'undefined' && user && user.role === 'superadmin' && !impersonating) { %>
        <a href="/superadmin" class="drawer-item">
          <span class="material-symbols-outlined">manage_accounts</span>
          <span>Superadministración</span>
        </a>
      <% } %>
      <% if (impersonating) { %>
        <a href="/exit-impersonate" class="drawer-item" style="color:#ea8600">
          <span class="material-symbols-outlined">swap_horiz</span>
          <span>Salir de vista</span>
        </a>
      <% } %>
    </div>
  </div>
</nav>
