<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Iniciar sesión - Classroom</title>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,0..200" />
  <link rel="icon" type="image/png" href="/favicon.png">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-body">
  <div class="auth-container">
    <div class="auth-card">
      <div class="auth-logo">
        <svg viewBox="0 0 390 135" xmlns="http://www.w3.org/2000/svg" style="width:100%;display:block;margin-bottom:6px">
          <defs>
            <clipPath id="lc"><circle cx="68" cy="68" r="60"/></clipPath>
            <linearGradient id="tg" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" style="stop-color:#1a3a6b"/>
              <stop offset="100%" style="stop-color:#74acdf"/>
            </linearGradient>
          </defs>
          <circle cx="68" cy="68" r="65" fill="#74acdf" opacity="0.25"/>
          <circle cx="68" cy="68" r="60" fill="none" stroke="#74acdf" stroke-width="3"/>
          <image href="/Logo.jpg" x="8" y="8" width="120" height="120" clip-path="url(#lc)" preserveAspectRatio="xMidYMid slice"/>
          <text x="152" y="54" font-family="'Segoe UI',Arial,sans-serif" font-size="35" font-weight="800" fill="url(#tg)">San José</text>
          <text x="152" y="96" font-family="'Segoe UI',Arial,sans-serif" font-size="35" font-weight="800" fill="url(#tg)">Conecta</text>
          <line x1="152" y1="108" x2="378" y2="108" stroke="#74acdf" stroke-width="3" stroke-linecap="round" opacity="0.6"/>
        </svg>
        <p class="auth-subtitle">Inicia sesión para continuar</p>
      </div>
      <form class="auth-form" id="loginForm">
        <div class="input-group">
          <span class="material-symbols-outlined input-icon">email</span>
          <input type="email" id="email" placeholder="Correo electrónico" required>
        </div>
        <div class="input-group">
          <span class="material-symbols-outlined input-icon">lock</span>
          <input type="password" id="password" placeholder="Contraseña" required>
        </div>
        <div class="form-error" id="loginError"></div>
        <button type="submit" class="btn btn-primary btn-full">
          <span class="material-symbols-outlined">login</span>
          Iniciar sesión
        </button>
      </form>
      <p class="auth-link">¿No tienes cuenta? <a href="#" onclick="abrirModalDni(event)">Regístrate</a></p>
    </div>
  </div>

  <!-- ── Modal búsqueda por DNI ── -->
  <div id="dniModalBackdrop" style="
    display:none;position:fixed;inset:0;
    background:rgba(0,0,0,.55);z-index:1000;
    align-items:flex-start;justify-content:center;
    overflow-y:auto;padding:16px;
  ">
    <div style="
      background:#fff;border-radius:16px;
      width:100%;max-width:440px;
      box-shadow:0 8px 40px rgba(0,0,0,.25);
      margin:auto;
      display:flex;flex-direction:column;
      overflow:hidden;box-sizing:border-box;
    ">
      <!-- Cabecera fija -->
      <div style="
        background:#1a73e8;color:#fff;
        padding:16px 20px;border-radius:16px 16px 0 0;
        display:flex;align-items:center;gap:10px;flex-shrink:0;
      ">
        <span class="material-symbols-outlined" style="font-size:24px">manage_accounts</span>
        <div style="min-width:0">
          <div style="font-size:16px;font-weight:700;line-height:1.2">Buscar mi cuenta</div>
          <div style="font-size:12px;opacity:.85;margin-top:2px">Ingresá tu DNI para ver tus datos de acceso</div>
        </div>
        <button onclick="cerrarModal()" style="
          margin-left:auto;flex-shrink:0;
          background:rgba(255,255,255,.2);border:none;
          color:#fff;border-radius:50%;width:30px;height:30px;
          cursor:pointer;display:flex;align-items:center;justify-content:center;
        ">
          <span class="material-symbols-outlined" style="font-size:18px">close</span>
        </button>
      </div>

      <!-- Cuerpo con scroll propio si el contenido crece -->
      <div style="padding:20px;flex:1;overflow-x:hidden;min-width:0">
        <!-- Input DNI + Buscar -->
        <div style="display:flex;gap:8px;align-items:stretch">
          <div class="input-group" style="flex:1;margin-bottom:0">
            <span class="material-symbols-outlined input-icon">fingerprint</span>
            <input type="text" id="modalDniInput" placeholder="Número de DNI"
              maxlength="10" inputmode="numeric" pattern="[0-9]*"
              onkeydown="if(event.key==='Enter') buscarDni()">
          </div>
          <button type="button" class="btn btn-primary" id="modalBuscarBtn"
            onclick="buscarDni()" style="white-space:nowrap;padding:0 16px;flex-shrink:0">
            <span class="material-symbols-outlined">search</span>
            <span class="buscar-text">Buscar</span>
          </button>
        </div>

        <div class="form-error" id="modalDniError" style="margin-top:10px"></div>

        <!-- Resultado -->
        <div id="modalDniResult" style="margin-top:14px"></div>

        <!-- Pie -->
        <div style="margin-top:16px;text-align:center;padding-top:14px;border-top:1px solid #e0e0e0">
          <span style="font-size:13px;color:#666">
            ¿No encontrás tu cuenta?
            <a href="/register" style="color:#1a73e8;font-weight:600">Crear cuenta nueva</a>
          </span>
        </div>
      </div>
    </div>
  </div>

  <script src="/js/login.js"></script>
  <script>
    function abrirModalDni(e) {
      e.preventDefault();
      document.body.style.overflow = 'visible';
      document.getElementById('dniModalBackdrop').style.display = 'flex';
      document.getElementById('modalDniInput').focus();
    }

    function cerrarModal() {
      document.body.style.overflow = '';
      document.getElementById('dniModalBackdrop').style.display = 'none';
      document.getElementById('modalDniInput').value = '';
      document.getElementById('modalDniError').classList.remove('show');
      document.getElementById('modalDniError').textContent = '';
      document.getElementById('modalDniResult').innerHTML = '';
    }

    // Cerrar al hacer clic en el fondo
    document.getElementById('dniModalBackdrop').addEventListener('click', function(e) {
      if (e.target === this) cerrarModal();
    });

    // Cerrar con Escape
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') cerrarModal();
    });

    async function buscarDni() {
      const input   = document.getElementById('modalDniInput');
      const errorEl = document.getElementById('modalDniError');
      const resultEl = document.getElementById('modalDniResult');
      const btn     = document.getElementById('modalBuscarBtn');

      const dni = input.value.replace(/\D/g, '').trim();
      errorEl.classList.remove('show');
      errorEl.textContent = '';
      resultEl.innerHTML = '';

      if (dni.length < 6) {
        errorEl.textContent = 'Ingresá un DNI válido (mínimo 6 dígitos).';
        errorEl.classList.add('show');
        return;
      }

      btn.disabled = true;
      btn.innerHTML = '<span class="material-symbols-outlined" style="animation:spin 1s linear infinite;font-size:18px">progress_activity</span>';

      try {
        const res  = await fetch(`/register/lookup?dni=${encodeURIComponent(dni)}`);
        const data = await res.json();

        if (!res.ok) {
          errorEl.textContent = data.error || 'No se encontró ningún usuario con ese DNI.';
          errorEl.classList.add('show');
          return;
        }

        resultEl.innerHTML = data.users.map(u => `
          <div style="
            border:1.5px solid #1a73e8;border-radius:12px;
            padding:16px 18px;background:#f0f6ff;margin-bottom:10px;
            overflow:hidden;box-sizing:border-box;
          ">
            <div style="display:flex;align-items:center;gap:7px;margin-bottom:12px">
              <span class="material-symbols-outlined" style="color:#1a73e8;font-size:18px">check_circle</span>
              <strong style="color:#1a73e8;font-size:13px">Cuenta encontrada</strong>
            </div>
            <table style="width:100%;border-collapse:collapse;font-size:13.5px;table-layout:fixed">
              <tr>
                <td style="padding:4px 0;color:#666;width:90px;white-space:nowrap">DNI</td>
                <td style="padding:4px 0;font-weight:700;word-break:break-all">${u.dni}</td>
              </tr>
              <tr>
                <td style="padding:4px 0;color:#666;white-space:nowrap">Nombre</td>
                <td style="padding:4px 0;font-weight:600;word-break:break-word">${u.name}</td>
              </tr>
              <tr>
                <td style="padding:4px 0;color:#666;white-space:nowrap">Correo</td>
                <td style="padding:4px 0;word-break:break-all">${u.email}</td>
              </tr>
              <tr>
                <td style="padding:4px 0;color:#666;vertical-align:top;white-space:nowrap">Contraseña</td>
                <td style="padding:4px 0">
                  <span style="
                    display:inline-block;background:#fff3cd;
                    border:1px solid #f0c040;border-radius:6px;
                    padding:2px 10px;font-weight:700;
                    font-family:monospace;letter-spacing:1px;color:#856404;
                  ">${u.dni}</span>
                  <span style="font-size:11px;color:#666;display:block;margin-top:2px">
                    Tu contraseña inicial es tu número de DNI
                  </span>
                </td>
              </tr>
            </table>
            <a href="/login" onclick="cerrarModal()" class="btn btn-primary btn-full"
              style="margin-top:14px;text-decoration:none;display:flex;justify-content:center;align-items:center;gap:6px;font-size:14px;box-sizing:border-box">
              <span class="material-symbols-outlined">login</span>
              Ir a iniciar sesión
            </a>
          </div>
        `).join('');

      } catch {
        errorEl.textContent = 'Error de conexión. Intentá de nuevo.';
        errorEl.classList.add('show');
      } finally {
        btn.disabled = false;
        btn.innerHTML = '<span class="material-symbols-outlined">search</span> Buscar';
      }
    }
  </script>
  <style>
    @keyframes spin { from{transform:rotate(0deg)} to{transform:rotate(360deg)} }

    /* Fondo Argentina */
    body.auth-body {
      overflow-y: auto !important;
      align-items: flex-start !important;
      background: linear-gradient(160deg, #4a8fc4 0%, #daeeff 50%, #4a8fc4 100%) !important;
      min-height: 100vh;
    }
    body.auth-body::before,
    body.auth-body::after {
      display: none !important;
    }
    .auth-container {
      margin: auto;
      padding: 20px 16px;
    }

    /* El backdrop del modal ocupa toda la pantalla y tiene su propio scroll */
    #dniModalBackdrop {
      align-items: flex-start !important;
    }

    @media (max-width: 480px) {
      .auth-card { padding: 28px 20px !important; }
      .buscar-text { display: none; }
      #modalBuscarBtn { padding: 0 12px; }
    }

    @media (max-height: 600px) {
      .auth-card { padding: 20px 24px !important; }
      .auth-logo { margin-bottom: 10px !important; }
    }
    @media (max-height: 420px) {
      .auth-logo { display: none !important; }
      .auth-card { padding: 14px 20px !important; }
    }
  </style>
</body>
</html>
